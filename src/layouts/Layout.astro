---
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Chatbot from "../components/Chatbot.astro";
import Loader from "../components/Loader.astro";

type Translations = typeof import("../i18n/en").default;

export interface Props {
  lang: string;
  t?: Translations;
  showLoader?: boolean; 
}

const { lang, t, showLoader = true } = Astro.props;
---

<!doctype html>
<html lang={lang} class="overflow-x-clip ">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <style is:inline>
      /* Estado inicial del body */
      body { background: #003b46; } 

      /* Imagen/video de fondo del hero en su estado normal */
      .hero-main-image {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
        pointer-events: none;
      }

      /* Estilos de revelado de contenido */
      .hero-main-section .container-full {
        opacity: 0;
        pointer-events: none;
      }

      body.content-reveal .hero-main-section .container-full {
        opacity: 1;
        pointer-events: auto;
        animation: fadeUp 0.6s ease-out forwards;
      }

      header#site-header {
        opacity: 0;
        pointer-events: none;
      }

      body.content-reveal header#site-header {
        opacity: 1;
        pointer-events: auto;
        animation: fadeDown 0.6s ease-out forwards;
      }

      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
      }

      @keyframes fadeDown {
        from { opacity: 0; transform: translateY(-30px); }
        to { opacity: 1; transform: translateY(0); }
      }

      /* ESTADO INICIAL del recorte del loader */
      #page-loader.loader-cutout-scale {
        animation: loaderCutoutScale 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
      }

      @keyframes loaderCutoutScale {
        from {
          clip-path: polygon(0% 0%, 0% 100%, 100% 100%, 100% 0%, 0% 0%, 50% 50%, 50% 50%, 50% 50%, 50% 50%, 50% 50%);
        }
        to {
          clip-path: polygon(0% 0%, 0% 100%, 100% 100%, 100% 0%, 0% 0%, calc(50% - 200px) calc(50% - 258px), calc(50% + 200px) calc(50% - 258px), calc(50% + 200px) calc(50% + 258px), calc(50% - 200px) calc(50% + 258px), calc(50% - 200px) calc(50% - 258px));
        }
      }

      /* ESTADO 2: Expansión del recorte del loader */
      #page-loader.loader-cutout-expand {
        animation: loaderCutoutExpand 0.8s ease-in-out forwards;
      }

      @keyframes loaderCutoutExpand {
        from {
          clip-path: polygon(0% 0%, 0% 100%, 100% 100%, 100% 0%, 0% 0%, calc(50% - 200px) calc(50% - 258px), calc(50% + 200px) calc(50% - 258px), calc(50% + 200px) calc(50% + 258px), calc(50% - 200px) calc(50% + 258px), calc(50% - 200px) calc(50% - 258px));
        }
        to {
          clip-path: polygon(0% 0%, 0% 100%, 100% 100%, 100% 0%, 0% 0%, 0% 0%, 100% 0%, 100% 100%, 0% 100%, 0% 0%);
        }
      }

    </style>

    <meta name="geo.region" content="US-FL" />
    <meta name="geo.placename" content="Orlando" />
    <meta name="geo.position" content="28.5383;-81.3792" />
    <meta name="ICBM" content="28.5383, -81.3792" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://widgets.leadconnectorhq.com" />
    <link rel="dns-prefetch" href="https://widgets.leadconnectorhq.com" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta name="generator" content={Astro.generator} />
    <title>Advance Rock Concrete</title>
    <meta name="description" content="Advance Rock Concrete provides the best concrete solutions for your construction needs." />
    <meta name="keywords" content="Concrete Solutions, Construction, Building Materials" />
    <meta name="author" content="Advance Rock Concrete" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://www.advancerockgroup.com/" />

    <link rel="alternate" hreflang="en" href="https://www.advancerockgroup.com/en/" />
    <link rel="alternate" hreflang="es" href="https://www.advancerockgroup.com/es/" />
    <link rel="alternate" hreflang="x-default" href="https://www.advancerockgroup.com/en/" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content="Advance Rock Concrete - The Ultimate Solution" />
    <meta property="og:description" content="Advance Rock Concrete provides the best concrete solutions for your construction needs." />
    <meta property="og:url" content="https://www.advancerockgroup.com/" />
    <meta property="og:image" content="/images/fondo.png" />
    <meta property="og:locale" content={lang === "es" ? "es_US" : "en_US"} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@AdvanceRock" />
    <meta name="twitter:title" content="Advance Rock Concrete - The Ultimate Solution" />
    <meta name="twitter:description" content="Advance Rock Concrete provides the best concrete solutions for your construction needs." />
    <meta name="twitter:image" content="/images/fondo.png" />

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Advance Rock Concrete",
        "url": "https://www.advancerockgroup.com/",
        "logo": "https://www.advancerockgroup.com/favicon.svg"
      }
    </script>
  </head>
  
  <body
    class="font-family antialiased overflow-x-clip bg-white flex flex-col justify-center items-center w-full"
    data-show-loader={showLoader ? 'true' : 'false'}
  >
    {showLoader && <Loader />}
    <Header content={t?.header} />
    <main class="flex flex-col w-full items-center">
      <slot />
    </main>
    <Footer content={t?.footer} />
    <Chatbot />
    <script>
      import { ScrollTrigger } from '../utils/animations';

      window.addEventListener('load', () => {
        ScrollTrigger.refresh();
      });
    </script>
    <script>
      import { initAnimations, ScrollTrigger } from '../utils/animations';

      function setupSequence() {
        const body = document.body;
        const showLoader = body.getAttribute('data-show-loader') === 'true';
        
        const loader = document.getElementById('page-loader') || 
                       document.querySelector('.loader') || 
                       document.querySelector('.js-loader') as HTMLElement | null;

        let animationPhase = 0;

        try {
          ScrollTrigger.refresh();
          initAnimations();
        } catch (e) {
          console.warn("GSAP no inicializado aún:", e);
        }

        // FASE 0: Quitar Loader agregando un retraso artificial de 1.4s
        function removeLoaderAndStart() {
          if (loader && showLoader) {
            // Espera 1.4 segundos antes de comenzar
            setTimeout(() => {
              // 1. Pausar el video para congelarlo en el fotograma actual
              const loaderVideo = loader.querySelector('video');
              if (loaderVideo) {
                loaderVideo.pause();
              }

              // Dejar el loader al frente para que la animación del recorte sea visible sobre la página
              startLoaderCutoutScale();
            }, 1400); // Retraso de 1.4s (1400 milisegundos)
          } else {
            if (loader) loader.remove();
            body.style.background = '';
            revealContent();
          }
        }

        // --- ANIMACIÓN DE CUTOUT (VÍA OVERLAY LOADER) ---
        // FASE 1: Animación de escala inicial del recorte del loader
        function startLoaderCutoutScale() {
          animationPhase = 11;
          loader?.addEventListener('animationend', handleLoaderAnimationEnd);
          loader?.classList.add('loader-cutout-scale');

          setTimeout(() => {
            if (animationPhase === 11) startLoaderCutoutExpand();
          }, 700);
        }

        // FASE 2: Expansión del recorte a pantalla completa
        function startLoaderCutoutExpand() {
          animationPhase = 12;
          if (loader) {
            loader.classList.remove('loader-cutout-scale');
            loader.classList.add('loader-cutout-expand');
          }

          setTimeout(() => {
            if (animationPhase === 12) revealContent();
          }, 900);
        }

        // Manejador de eventos de animación CSS para el Loader
        function handleLoaderAnimationEnd(e: AnimationEvent) {
          if (animationPhase === 11 && e.animationName === 'loaderCutoutScale') {
            startLoaderCutoutExpand();
          } else if (animationPhase === 12 && e.animationName === 'loaderCutoutExpand') {
            revealContent();
            loader?.removeEventListener('animationend', handleLoaderAnimationEnd);
          }
        }

        // FASE 3: Revelar el Header y el Contenido restante
        function revealContent() {
          animationPhase = 3;
          body.classList.add('content-reveal');
          
          // Eliminar el loader por completo ahora que la animación ha terminado
          if (loader) {
            loader.remove();
            body.style.background = '';
          }

          // Despachar un evento personalizado para notificar que la animación terminó
          document.dispatchEvent(new CustomEvent('loader-complete'));
          
          setTimeout(() => {
            const header = document.getElementById('site-header');
            if (header) {
              header.style.animation = 'none';
            }
          }, 650);
        }

        removeLoaderAndStart();
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setupSequence);
      } else {
        setupSequence();
      }
    </script>
  </body>
</html>

<script is:inline >
  document.addEventListener("DOMContentLoaded", () => {
    const animationElements = document.querySelectorAll(
      ".animation-up-fast, .animation-fade-down, .animation-fade-left, .animation-fade-right"
    );

    const animationObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("active");
            animationObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.3 }
    );

    animationElements.forEach((element) => {
      animationObserver.observe(element);
    });
  });
</script>