---
type Translations = typeof import("../i18n/en").default;
type InfoContent = Translations["services"]["pool-construction"]["info"];
interface Props {
  content: InfoContent;
  styleType?: string;
  list?: {
    title: string;
    description: string;
  }[];
}
const { content, styleType, list } = Astro.props as Props;
---

<div
  class={`flex flex-col xl:flex-row w-full justify-center xl:justify-between js-service-row-item h-auto xl:h-screen 3xl:h-auto px-4 xl:px-0 gap-6 ${styleType == "bg-and-order" ? "py-16 xl:py-12 3xl:py-20" : "pt-16 xl:pt-12 3xl:pt-20"}`}
  data-style-type={styleType}
>
  {/* Mitad de Texto */}
  <div
    class={`w-full flex items-center js-serv-item-content ${styleType == "bg-and-order" ? "order-1 xl:order-2 xl:w-[60%]" : "order-1 xl:w-1/2"}`}
  >
    <div
      class={`w-full flex flex-col gap-6 items-start ${styleType == "bg-and-order" ? "mr-auto pl-0 xl:pl-24" : "pr-5 xl:ml-auto max-w-[640px]"}`}
    >
      <div class="w-3 h-3 bg-accent"></div>
      <h2
        class={`title text-left ${styleType == "bg-and-order" ? "text-secondary" : "text-primary"}`} set:html={content.title}
      >
        
      </h2>
      <p
        set:html={content.subtitle}
        class={`subtitle w-full xl:w-[80%] ${styleType == "bg-and-order" ? "text-white" : "text-paragraph"}`}
      />
      <p
        set:html={content.description}
        class={`paragraph w-full xl:w-[80%] ${styleType == "bg-and-order" ? "text-white" : "text-paragraph"}`}
      />
      {
        list && (
          <div class="grid grid-cols-1 md:grid-cols-3 justify-center items-stretch gap-4">
            {list.map((item) => (
              <div class="flex flex-col justify-start items-start gap-2 p-4 rounded-0 xl:rounded-[4px] border border-white/10 max-w-none xl:max-w-[170px] text-white grow">
                <h3 class="paragraph-bold">{item.title}</h3>
                <p class="paragraph" set:html={item.description} />
              </div>
            ))}
          </div>
        )
      }
    </div>
  </div>

  {/* Mitad de Imagen */}
  <div
    class={`w-full lg:w-auto 3xl:w-[40%] h-auto min-h-[300px] lg:h-full 3xl:h-auto relative js-serv-item-image ${styleType == "bg-and-order" ? "order-1" : "order-2"}`}
    style="aspect-ratio: 1/1;"
  >
    <img
      class="w-full h-full object-cover absolute inset-0 object-center"
      src={`/images/${content.image}.webp`}
      alt={content.title}
      width="640"
      height="640"
      decoding="async"
      loading="lazy"
    />
  </div>
</div>

<script>
  import { gsap, ScrollTrigger } from "../utils/animations";

  let servicesTriggers: any[] = [];

  const destroyServicesAnimation = () => {
    servicesTriggers.forEach((trigger) => {
      if (trigger) trigger.kill(true);
    });
    servicesTriggers = [];
  };

  const initServicesAnimation = () => {
    gsap.registerPlugin(ScrollTrigger);
    destroyServicesAnimation();

    const rows = document.querySelectorAll(".js-service-row-item");

    rows.forEach((row) => {
      const image = row.querySelector(".js-serv-item-image") as HTMLElement;
      const content = row.querySelector(".js-serv-item-content") as HTMLElement;

      if (!image || !content) return;

      // Detectamos si esta fila específica tiene el estilo 'bg-and-order'
      const isBgAndOrder =
        row.getAttribute("data-style-type") === "bg-and-order";

      const imageOrigin = isBgAndOrder ? "top left" : "top right";
      const textXOffset = isBgAndOrder ? 100 : -100;

      // === ESTADOS INICIALES ===
      gsap.set(image, {
        scale: 0,
        opacity: 0,
        transformOrigin: imageOrigin,
      });

      gsap.set(content, {
        opacity: 0,
        xPercent: textXOffset,
      });

      // === TIMELINE DE SCROLL CONTINUO ===
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: row,
          start: "top 80%",
          end: "+=700",
          scrub: 1,
          invalidateOnRefresh: true,
        },
      });

      tl.to(image, {
        opacity: 1,
        scale: 1,
        duration: 1,
        ease: "none",
      }).to(
        content,
        {
          opacity: 1,
          xPercent: 0, 
          duration: 0.8,
          ease: "power2.out",
        },
        "-=0.5",
      );

      if (tl.scrollTrigger) servicesTriggers.push(tl.scrollTrigger);
    });

    ScrollTrigger.refresh();
  };

  document.addEventListener("DOMContentLoaded", initServicesAnimation);
  document.addEventListener("astro:page-load", initServicesAnimation);
  document.addEventListener("astro:before-swap", destroyServicesAnimation);
</script>
