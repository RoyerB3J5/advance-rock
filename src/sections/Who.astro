---
type Translations = typeof import("../i18n/en").default;
type WhoContent = Translations["about"]["who"];
interface Props {
  content: WhoContent;
}
const { content } = Astro.props as Props;

const socialMedia = [
  {
    icon: "facebook-2",
    href: "#",
  },
  {
    icon: "instagram-2",
    href: "https://www.instagram.com/advancerockconcrete.usa?igsh=cGlndHF6anRyMHBn",
  },
];
---
<section data-scroll-snap class="js-who-section w-full h-auto xl:h-screen bg-white overflow-hidden relative py-0 xl:py-12 3xl:py-20">
  <div class="grid grid-cols-1 xl:grid-cols-[minmax(1.5rem,1fr)_minmax(0,746px)_minmax(0,534px)_minmax(1.5rem,1fr)] w-full h-full">
    
    {/* Contenido Izquierdo */}
    <div class="col-start-1 xl:col-start-2 xl:col-end-3 px-4 xl:px-0 xl:pr-16 flex flex-col justify-center xl:justify-between items-start h-full gap-12 xl:gap-0 relative z-10 text-wrapper order-2 xl:order-1 py-16 xl:py-0">
      <div class="flex flex-col justify-center items-start gap-5 js-who-first">
        <h2 class="text-primary title">{content.title}</h2>
        <p class="text-paragraph subtitle">{content.subtitle}</p>
        <p class="text-paragraph paragraph">{content.description}</p>
        <p class="text-primary paragraph-bold">{content.medias}</p>
        <div class="flex justify-start items-center gap-2">
          {
            socialMedia.map((item) => (
              <a href={item.href} class="p-2">
                <img
                  src={`/images/${item.icon}.svg`}
                  width="24"
                  height="24"
                  class="w-6 h-6"
                  decoding="async"
                  loading="lazy"
                  alt={item.icon}
                />
              </a>
            ))
          }
        </div>
      </div>

      <div class="w-full flex flex-col lg:flex-row justify-center lg:justify-start xl:justify-between items-start lg:items-end gap-6 xl:gap-0 js-who-second">
        <img src="/images/logo-4.svg" alt="Logo" width="250" height="244" class="w-[200px]  3xl:w-[250px] h-auto" decoding="async" loading="lazy"/>
        <p class="text-paragraph subtitle lg:w-[40%]">{content.description2}</p>
      </div>

    </div>

    {/* Imagen Derecha */}
    <div class="col-start-1 xl:col-start-3 xl:col-end-5 relative h-auto md:h-[400px] lg:h-full z-20 js-who-image order-1 xl:order-2 w-full xl:w-auto aspect-81/100 xl:aspect-auto">
      <div class="relative xl:absolute xl:top-0 xl:right-0 h-full w-full xl:w-auto js-image-wrapper" style="aspect-ratio: 700/740;">
        <img 
          src="/images/who.webp" 
          alt="Sobre Nosotros" 
          class="w-full h-full xl:absolute inset-0 object-cover object-center" 
          decoding="async" 
          loading="lazy"
          width="2300"
          height="1284"
        />
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap, ScrollTrigger } from '../utils/animations';
  import { MEDIA_QUERIES } from '../utils/breakpoints';
  let whoTriggers: any[] = [];

  const destroyWhoAnimation = () => {
    whoTriggers.forEach(trigger => {
      if (trigger) trigger.kill(true); 
    });
    whoTriggers = [];

    const sections = document.querySelectorAll('.js-who-section');
    sections.forEach(section => {
      const panelGrowth = section.querySelector('.js-who-image');
      const imageWrapper = section.querySelector('.js-image-wrapper');
      const contentBlock1 = section.querySelector('.js-who-first');
      const fadeLeftP = section.querySelector('.js-who-second');

      if (panelGrowth) gsap.set(panelGrowth, { clearProps: "all" });
      if (imageWrapper) gsap.set(imageWrapper, { clearProps: "all" });
      if (contentBlock1) gsap.set(contentBlock1, { clearProps: "all" });
      if (fadeLeftP) gsap.set(fadeLeftP, { clearProps: "all" });
    });
  };

  const initWhoAnimation = () => {
    gsap.registerPlugin(ScrollTrigger);
    destroyWhoAnimation();

    const sections = document.querySelectorAll('.js-who-section');
    let mm = gsap.matchMedia();
    
    sections.forEach((section) => {
      const panelGrowth = section.querySelector('.js-who-image') as HTMLElement;
      const imageWrapper = section.querySelector('.js-image-wrapper') as HTMLElement;
      const contentBlock1 = section.querySelector('.js-who-first');
      const fadeLeftP = section.querySelector('.js-who-second');

      if (!panelGrowth || !imageWrapper || !contentBlock1 || !fadeLeftP) return;

      // ==========================================
      // 1. ESCRITORIO (730px en adelante)
      // ==========================================
      mm.add(MEDIA_QUERIES.isDesktopPin, () => {
        gsap.set(panelGrowth, { opacity: 0, scale: 0, transformOrigin: "top right" });
        gsap.set(contentBlock1, { opacity: 0, y: 100 });
        gsap.set(fadeLeftP, { opacity: 0, y: 100 });
        gsap.set(imageWrapper, { width: "auto", aspectRatio: "700/740" });

        const introDistance = window.innerHeight * 0.75; 
        const pinDistance = 3500; 

        const pinTrigger = ScrollTrigger.create({
          trigger: section,
          start: "top top",
          pin: true,
          pinSpacing: true,
          end: `+=${pinDistance}`,
          invalidateOnRefresh: true
        });
        if (pinTrigger) whoTriggers.push(pinTrigger);

        const tl = gsap.timeline({
          scrollTrigger: {
            trigger: section,
            start: "top 75%", 
            end: `+=${introDistance + pinDistance}`, 
            scrub: 2, 
            invalidateOnRefresh: true 
          }
        });

        tl.to(panelGrowth, { opacity: 1, scale: 1, duration: introDistance * 0.4, ease: "none" })
          .to(contentBlock1, { opacity: 1, y: 0, duration: introDistance * 0.4, ease: "power2.out" }, `-=${introDistance * 0.2}`)
          .to(fadeLeftP, { opacity: 1, y: 0, duration: introDistance * 0.4, ease: "power2.out" }, `-=${introDistance * 0.1}`)
          .addLabel('granExpansion', introDistance)
          .to(imageWrapper, { width: "100vw", aspectRatio: "auto", duration: pinDistance, ease: "power2.inOut" }, 'granExpansion')
          .to(section, { paddingTop: 0, paddingBottom: 0, duration: pinDistance, ease: "power2.inOut" }, 'granExpansion');

        if (tl.scrollTrigger) whoTriggers.push(tl.scrollTrigger);
      });

      // ==========================================
      // 2. MÓVIL Y TABLET (729px hacia abajo)
      // ==========================================
      mm.add(MEDIA_QUERIES.isTabletMobileFlow, () => {
        // Corrección de renderizado: Forzamos transform-style y evitamos bugs de parpadeo (will-change)
        gsap.set(panelGrowth, { 
          opacity: 0, 
          scale: 0, 
          transformOrigin: "top left",
          force3D: true,
          clearProps: "willChange"
        });
        
        gsap.set(contentBlock1, { opacity: 0, xPercent: 100, force3D: true });
        gsap.set(fadeLeftP, { opacity: 0, xPercent: -100, force3D: true });

        const tlMobile = gsap.timeline({
          scrollTrigger: {
            trigger: section,
            start: "top 85%", // Un poco antes para que la transición sea orgánica
            end: () => window.innerWidth >= 1024 ? "+=1900" : "+=1200",
            scrub: 1.2, // Reducido ligeramente para acoplarse mejor a pantallas táctiles
            invalidateOnRefresh: true
          }
        });

        // Secuencia lineal ultra-fluida
        tlMobile.to(panelGrowth, {
          opacity: 1,
          scale: 1,
          duration: 1.2,
          ease: "none" // Cambiado a 'none' para eliminar el rebote provocado por el scrub
        })
        .to(contentBlock1, {
          opacity: 1,
          xPercent: 0,
          duration: 1,
          ease: "power1.out"
        }, "+=0.2")
        .to(fadeLeftP, {
          opacity: 1,
          xPercent: 0,
          duration: 1,
          ease: "power1.out"
        }, "+=0.2");

        if (tlMobile.scrollTrigger) whoTriggers.push(tlMobile.scrollTrigger);
      });

    });

    ScrollTrigger.refresh();
  };

  document.addEventListener('DOMContentLoaded', initWhoAnimation);
  document.addEventListener('astro:page-load', initWhoAnimation);
  document.addEventListener('astro:before-swap', destroyWhoAnimation);
</script>