---
import Button from "../components/Button.astro";

type Translations = typeof import("../i18n/en").default;
type HeroContent = Translations["main"]["hero"];
interface Props {
  content: HeroContent;
}
const { content } = Astro.props as Props;
---
<section class="relative flex w-full h-screen justify-center items-center hero-main-section overflow-hidden">
  <img src="/images/hero-main.webp" alt="Hero Image" width="2500" height="1563" class="hero-main-image object-cover z-0 pointer-events-none"/>
  
  <div class="container-full flex flex-col justify-end items-start py-12 z-10 h-full gap-4">
    <h1 class="text-[80px] font-extrabold leading-[100%] text-white uppercase" set:html={content.title}></h1>
    <Button
      text={content.button.label}
      href={content.button.href}
      textClass="text-[17px]"
    />
  </div>
</section>