---
import type { Language } from '../types/language.type';
type Translations = typeof import("../i18n/en").default;
type BrandsContent = Translations["about"]["brands"];
interface Props {
  content: BrandsContent;
}
const { content } = Astro.props as Props;


const colorContent = [
  {
    back:'bg-primary',
    textTitle:'text-secondary',
  },
  {
    back:'bg-secondary',
    textTitle:'text-primary',
  },
  {
    back:'bg-[#1E1E1E]',
    textTitle:'text-secondary',
  },
  {
    back:'bg-[#ED1846]',
    textTitle:'text-[#561111]',
  },
]
const lang = Astro.params.lang as Language;
---
<section class="w-full flex flex-col justify-center items-center bg-white pt-12 lg:py-20 gap-20">
  <div class="w-full flex flex-col justify-center items-center gap-8">
    <h2 class='title-sm text-primary'>{content.title}</h2>
  </div>
  <div class="flex flex-col justify-center items-center gap-6 w-full">
    {
      content.items.map((item, index) =>( 
        <div class="grid grid-cols-1 lg:grid-cols-2 lg:gap-6 w-full">
          <div class={`w-full h-auto flex flex-col justify-start items-start py-10 px-4 lg:p-10 xl:p-20 gap-10 lg:gap-0 ${colorContent[index].back} aspect-auto lg:aspect-[708/700]`} >

          <div class="flex flex-col justify-center items-start gap-6">
            <h3 class={`title-2 ${colorContent[index].textTitle}`}>{item.title}</h3>
            <p class="text-white paragraph">{item.description}</p>
          </div>

          <img 
            src={`/images/${item.icon}.svg`} 
            alt={item.title} 
            class="w-16 h-16 object-cover mt-auto self-end" 
            decoding="async" 
            loading="lazy" 
            width="64" 
            height="64" 
          />

        </div>
          <div class="w-full h-auto flex relative aspect-[375/392] lg:aspect-[708/700]" >
            <img src={`/images/${item.image}.webp`} alt={item.title} class="w-full h-full object-cover absolute inset-0 object-cover" decoding="async" loading="lazy" width="708" height="700"/>
          </div>
        </div>
      ))
    }
  </div>
</section>