</section>

<style>
  /* Escritorio: Animaciones del mapa solo con Hover en pantallas grandes (xl / 1280px) */
  @media (min-width: 1280px) {
    .map-container:has(.map-pin:hover) .map-image {
      transform: scale(1.05);
    }
    .map-container:has(.map-pin:hover) .map-blur {
      opacity: 1;
    }
  }

  /* Control de blur dinámico vía clases (Para Mobile y Tablets) */
  .map-container.has-active-pin .map-image {
    transform: scale(1.05);
  }
  .map-container.has-active-pin .map-blur {
    opacity: 1;
  }
</style>

<script>
  const initMapInteractions = () => {
    const mapContainer = document.getElementById('map-container');
    const pins = document.querySelectorAll('.map-pin');
    
    if (!mapContainer) return;

    pins.forEach(pin => {
      const trigger = pin.querySelector('.cursor-pointer');
      
      trigger?.addEventListener('click', (e) => {
        // Unificamos el breakpoint de mobile/tablet a menor que 'xl' (1279px para abajo)
        const isMobileOrTablet = window.matchMedia('(max-width: 1279px)').matches;
        
        if (isMobileOrTablet) {
          e.stopPropagation();
          
          const isActive = pin.classList.contains('is-active');
          
          if (isActive) {
            // Si hacemos click en el pin activo, limpiamos todo y quitamos el blur
            mapContainer.classList.remove('has-active-pin');
            pins.forEach(p => {
              p.classList.remove('is-active');
              p.classList.remove('hidden');
            });
          } else {
            // Si activamos un pin nuevo, encendemos el blur en el contenedor
            mapContainer.classList.add('has-active-pin');
            pins.forEach(p => {
              if (p === pin) {
                p.classList.add('is-active');
                p.classList.remove('hidden');
              } else {
                p.classList.remove('is-active');
                p.classList.add('hidden');
              }
            });
          }
        }
      });
    });

    // UX: Al hacer click fuera de los pines (en cualquier parte del documento)
    document.addEventListener('click', () => {
      const isMobileOrTablet = window.matchMedia('(max-width: 1279px)').matches;
      if (isMobileOrTablet) {
        mapContainer.classList.remove('has-active-pin');
        pins.forEach(p => {
          p.classList.remove('is-active');
          p.classList.remove('hidden');
        });
      }
    });
  };

  document.addEventListener('DOMContentLoaded', initMapInteractions);
  document.addEventListener('astro:page-load', initMapInteractions);
</script>