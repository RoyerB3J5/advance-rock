---
type Translations = typeof import('../i18n/en').default;
type InfoContent = Translations['services']['pool-construction']['info'];
interface Props {
  content: InfoContent;
}
const { content } = Astro.props as Props;
---

<div 
  class={`flex flex-col lg:flex-row w-full justify-between js-section-2-info h-screen  pt-12 3xl:pt-20 bg-white`}
>
  {/* Mitad de Texto */}
  <div class={`w-full flex items-center js-content-2-info order-1 lg:w-1/2`}>
    <div class={`w-full flex flex-col gap-6 items-start pr-5 ml-auto max-w-[640px]`}>
      <div class="w-3 h-3 bg-accent"></div>
      <h2 class={`title text-left text-primary`}>
        {content.title}
      </h2>
      <p set:html={content.subtitle} class={`subtitle w-[80%] text-paragraph`}></p>
      <p set:html={content.description} class={`paragraph w-[80%] text-paragraph`}></p>
    </div>
  </div>

  {/* Mitad de Imagen */}
  <div class={`w-full lg:w-auto 3xl:w-[40%] h-auto min-h-[300px] lg:h-full 3xl:h-auto relative js-image-2-info order-2`} style="aspect-ratio: 1/1;">
    <img 
      class="w-full h-full object-cover absolute inset-0 object-center" 
      src={`/images/${content.image}.webp`} 
      alt={content.title} 
      width="640" 
      height="640" 
      decoding="async" 
      loading="lazy" 
    />
  </div>
</div>

<script>
  import { gsap, ScrollTrigger } from '../utils/animations';

  let servicesTriggers: any[] = [];

  const destroyServicesAnimation = () => {
    servicesTriggers.forEach(trigger => {
      if (trigger) trigger.kill(true);
    });
    servicesTriggers = [];
  };

  const initServicesAnimation = () => {
    gsap.registerPlugin(ScrollTrigger);
    destroyServicesAnimation();

    const rows = document.querySelectorAll('.js-section-2-info');

    rows.forEach((row) => {
      const image = row.querySelector('.js-image-2-info') as HTMLElement;
      const content = row.querySelector('.js-content-2-info') as HTMLElement;

      if (!image || !content) return;

      const imageOrigin =  "top right";
      const textXOffset =  -100;

      // === ESTADOS INICIALES ===
      gsap.set(image, { 
        scale: 0, 
        opacity: 0, 
        transformOrigin: imageOrigin 
      });
      
      gsap.set(content, { 
        opacity: 0, 
        xPercent: textXOffset 
      });

      // === TIMELINE DE SCROLL CONTINUO ===
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: row,
          start: "top 80%",         
          end: "+=700", 
          scrub: 1,                 
          invalidateOnRefresh: true
        }
      });

      tl.to(image, { 
        opacity: 1, 
        scale: 1, 
        duration: 1, 
        ease: "none" 
      })
      .to(content, { 
        opacity: 1, 
        xPercent: 0, // Regresa a su posición original (0) provocando el fade left o fade right correspondiente
        duration: 0.8, 
        ease: "power2.out"
      }, "-=0.5");

      if (tl.scrollTrigger) servicesTriggers.push(tl.scrollTrigger);
    });

    ScrollTrigger.refresh();
  };

  document.addEventListener('DOMContentLoaded', initServicesAnimation);
  document.addEventListener('astro:page-load', initServicesAnimation);
  document.addEventListener('astro:before-swap', destroyServicesAnimation);
</script>