---
type Translations = typeof import("../i18n/en").default;
type ItemsServicesContent = Translations["servicesPage"]["items"];
interface Props {
  content: ItemsServicesContent;
}
const { content } = Astro.props as Props;
---
<section class="w-full flex flex-col bg-white py-20">
  {
    content.map((item, index) => {
      const isPar = index % 2 === 0;
      return (
        /* Fila principal a pantalla completa, dividida en dos en escritorio */
        <div class="flex flex-col lg:flex-row w-full">
          
          {/* Mitad de Texto: Ocupa el 50% de la pantalla real */}
          <div class={`w-full lg:w-1/2 flex items-center  ${isPar ? 'order-1' : 'order-2'}`}>
            
            {/* Contenedor interno limitado a 640px (mitad de 1280px) */}
            <div class={`w-full max-w-[640px] flex flex-col gap-6 ${isPar ? 'ml-auto items-start' : 'mr-auto items-end'}`}>
              <div class="w-3 h-3 bg-accent"></div>
              <h2 class={`text-primary title ${isPar ? 'text-left' : 'text-right'}`}>
                {item.title}
              </h2>
              <p set:html={item.subtitle} class="text-paragraph subtitle"></p>
              <p set:html={item.description} class="text-paragraph paragraph"></p>
              <a 
                href={item.button.href} 
                class="text-primary paragraph-bold underline hover:text-accent transition-colors duration-300 ease-in-out"
              >
                {item.button.label}
              </a>
            </div>

          </div>

          {/* Mitad de Imagen (Bleed): Ocupa el otro 50% y toca los bordes */}
          <div class={`w-full lg:w-1/2 h-auto min-h-[300px] lg:min-h-full ${isPar ? 'order-2' : 'order-1'} relative`} style="aspect-ratio: 1/1;">
            <img 
              class="w-full h-full object-cover absolute inset-0 object-center" 
              src={`/images/${item.image}.webp`} 
              alt={item.title} 
              width="640" 
              height="640" 
              decoding="async" 
              loading="lazy" 
            />
          </div>
          
        </div>
      )
    })
  }
</section>