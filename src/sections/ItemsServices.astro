---
type Translations = typeof import("../i18n/en").default;
type ItemsServicesContent = Translations["servicesPage"]["items"];
interface Props {
  content: ItemsServicesContent;
}
const { content } = Astro.props as Props;
---
<section class="js-services-section w-full flex flex-col bg-white px-4 lg:px-0 overflow-auto py-16 lg:py-0">
  {
    content.map((item, index) => {
      const isPar = index % 2 === 0;
      return (
        /* Eliminamos cualquier restricción de altura forzada para permitir un flujo natural */
        <div class="js-service-row flex flex-col lg:flex-row w-full lg:items-stretch overflow-hidden relative bg-white">
          
          {/* Mitad de Texto */}
          <div class={`w-full lg:w-1/2 flex items-center py-12 lg:py-20 ${isPar ? 'order-2 lg:order-1' : 'order-2 '}`}>
            <div class={`w-full max-w-[640px] px-0  flex flex-col gap-6 px-0 md:px-4 xl:pl-0 ${isPar ? 'lg:ml-auto items-start ' : 'lg:mr-auto items-end'} js-content-services`}>
              <div class="w-3 h-3 bg-accent"></div>
              <h2 class={`text-primary title-2  ${isPar ? 'text-left' : 'text-right'}`}>
                {item.title}
              </h2>
              <p set:html={item.subtitle} class={`text-paragraph subtitle ${isPar ? 'text-left' : 'text-right'}`}></p>
              <p set:html={item.description} class={`text-paragraph paragraph ${isPar ? 'text-left' : 'text-right'}`}></p>
              <a 
                href={item.button.href} 
                class="text-primary paragraph-bold underline hover:text-accent transition-colors duration-300 ease-in-out"
              >
                {item.button.label}
              </a>
            </div>
          </div>

          {/* Mitad de Imagen */}
          <div 
            class={`w-full lg:w-1/2 h-auto min-h-[300px] lg:min-h-full ${isPar ? 'order-1 lg:order-2' : 'order-1'} relative js-service-image`} 
            style="aspect-ratio: 1/1;"
          >
            <img 
              class="w-full h-full object-cover absolute inset-0 object-center" 
              src={`/images/${item.image}.webp`} 
              alt={item.title} 
              width="640" 
              height="640" 
              decoding="async" 
              loading="lazy" 
            />
          </div>
          
        </div>
      )
    })
  }
</section>

<script>
  import { gsap, ScrollTrigger } from '../utils/animations';

  let servicesTriggers: any[] = [];

  const destroyServicesAnimation = () => {
    servicesTriggers.forEach(trigger => {
      if (trigger) trigger.kill(true);
    });
    servicesTriggers = [];
  };

  const initServicesAnimation = () => {
    gsap.registerPlugin(ScrollTrigger);
    destroyServicesAnimation();

    const rows = document.querySelectorAll('.js-service-row');
    
    // Tu mapa exacto de posiciones de origen para las 6 filas
    const originMap = [
      "top right", // Fila 1 (index 0)
      "top right", // Fila 2 (index 1)
      "top left",  // Fila 3 (index 2)
      "top right", // Fila 4 (index 3)
      "top left",  // Fila 5 (index 4)
      "top right"  // Fila 6 (index 5)
    ];

    rows.forEach((row, index) => {
      const image = row.querySelector('.js-service-image') as HTMLElement;
      const content = row.querySelector('.js-content-services') as HTMLElement;

      if (!image || !content) return;

      const isPar = index % 2 === 0;
      const imageOrigin = originMap[index] || "top right";
      const textXOffset = isPar ? -80 : 80;

      // === ESTADOS INICIALES ===
      gsap.set(image, { 
        scale: 0, 
        opacity: 0, 
        transformOrigin: imageOrigin 
      });
      
      gsap.set(content, { 
        opacity: 0, 
        x: textXOffset 
      });

      // === TIMELINE DE SCROLL CONTINUO (SIN PIN) ===
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: row,
          // "top 85%" -> La animación inicia apenas la fila asoma un 15% desde el fondo de la pantalla
          start: "top 90%",         
          // "top 30%" -> Termina de completarse antes de llegar a la parte superior del viewport
          end: "top 10%", 
          scrub: 1,                 
          invalidateOnRefresh: true
        }
      });

      // Escalado fluido sincronizado con el avance del scroll
      tl.to(image, { 
        opacity: 1, 
        scale: 1, 
        duration: 1, 
        ease: "none" // Usamos "none" en scrubs para que la velocidad sea 1:1 con tu dedo
      })
      // Entrada lateral del contenido de texto
      .to(content, { 
        opacity: 1, 
        x: 0, 
        duration: 0.7, 
        ease: "power1.out"
      }, "-=0.5"); // Comienza a aparecer a la mitad de la animación de la imagen

      if (tl.scrollTrigger) servicesTriggers.push(tl.scrollTrigger);
    });

    ScrollTrigger.refresh();
  };

  document.addEventListener('DOMContentLoaded', initServicesAnimation);
  document.addEventListener('astro:page-load', initServicesAnimation);
  document.addEventListener('astro:before-swap', destroyServicesAnimation);
</script>