---
import Button from "../components/Button.astro";

type Translations = typeof import("../i18n/en").default;
type HeroContent = Translations["about"]["hero"];
interface Props {
  content: HeroContent;
}
const { content } = Astro.props as Props;
const R2_BASE = import.meta.env.PUBLIC_R2_URL;
---
<section data-hero-section data-scroll-snap  class="relative flex w-full h-screen  justify-center items-center overflow-hidden hero-main-section">
  <div class="hero-main-image absolute w-full h-full inset-0 pointer-events-none">
    <video
      data-video
      muted={true}
      loop={true}
      playsinline={true}
      x-webkit-playsinline={true}
      preload="auto"
      controlslist="nodownload no remoteplayback" 
      disablepictureinpicture 
      oncontextmenu="return false;"
      class="absolute inset-0 w-full h-full object-cover object-top"
    >
      <source src={`${R2_BASE}/videos/${content.video}.mp4`} type="video/mp4" />
    </video>
  </div>  
  <div class="container-full flex flex-col justify-end items-start py-10 md:py-12 z-10 h-full gap-6 md:gap-4">
    <h1 class="text-[36px] md:text-[64px]  font-extrabold leading-[110%] md:leading-[100%] text-white uppercase" set:html={content.title}></h1>
    <Button
      text={content.button.label}
      href={content.button.href}
      textClass="text-[17px]"
      extraBtnClass="w-full md:w-auto"
    />
  </div>
</section>

<script>
  function initHeroVideo() {
    const section = document.querySelector('[data-hero-section]');
    if (!section) return;

    const video = section.querySelector('[data-video]') as HTMLVideoElement | null;
    if (!video) return;

    video.pause();

    const playVideo = () => {
      video.play().catch(err => console.log('Error de reproducción:', err));
    };

    document.addEventListener('loader-complete', playVideo, { once: true });

    const loader = document.getElementById('page-loader');
    if (!loader) {
      playVideo();
    }
  }

  initHeroVideo();
  document.addEventListener('astro:page-load', initHeroVideo);
</script>