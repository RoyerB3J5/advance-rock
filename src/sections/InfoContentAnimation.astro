---
type Translations = typeof import('../i18n/en').default;
type InfoContent = Translations['services']['pool-construction']['info'];
interface Props {
  content: InfoContent;
}
const { content  } = Astro.props as Props;

---
<section class="flex justify-center items-center bg-[#002127] py-20 w-full">
  <div class="flex flex-col lg:flex-row w-full">
          {/* Mitad de Texto: Ocupa el 50% de la pantalla real */}
          <div class={`w-full lg:w-1/2 flex items-center `}>
            {/* Contenedor interno limitado a 640px (mitad de 1280px) */}
            <div class={`w-full max-w-[640px] flex flex-col gap-6  items-start  pr-5 ml-auto`}>
              <div class="w-3 h-3 bg-accent"></div>
              <h2 class={` title text-left text-secondary`}>
                {content.title}
              </h2>
              <p set:html={content.subtitle} class={` subtitle w-[80%] text-white`}></p>
              <p set:html={content.description} class={`paragraph w-[80%] text-white`}></p>
              
            </div>
          </div>
          {/* Mitad de Imagen (Bleed): Ocupa el otro 50% y toca los bordes */}
          <div class={`w-full lg:w-1/2 h-auto min-h-[300px] lg:min-h-full relative `} style="aspect-ratio: 1/1;">
            <img 
              class="w-full h-full object-cover absolute inset-0 object-center" 
              src={`/images/${content.image}.webp`} 
              alt={content.title} 
              width="640" 
              height="640" 
              decoding="async" 
              loading="lazy" 
            />
          </div>
        </div>
</section>
