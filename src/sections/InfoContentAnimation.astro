---
type Translations = typeof import('../i18n/en').default;
type InfoContent = Translations['services']['pool-construction']['info'];
interface Props {
  content: InfoContent;
}
const { content } = Astro.props as Props;
---
<section data-scroll-snap class="js-animation-section w-full h-auto xl:h-screen bg-[#002127] overflow-hidden relative py-16 xl:py-12 3xl:py-20">
  
  <div class="grid grid-cols-1 lg:grid-cols-[minmax(1.5rem,1fr)_minmax(0,640px)_minmax(0,640px)_minmax(1.5rem,1fr)] w-full h-full px-6 lg:px-0 gap-6 xl:gap-0">
    
    {/* Contenido Izquierdo - Al estar primero en el HTML se renderiza arriba de la imagen en móviles */}
    <div class="col-start-1 lg:col-start-2 lg:col-end-3  flex flex-col justify-center h-full relative z-10 js-animation-text">
      
      <div class="w-full max-w-[640px] flex flex-col gap-6 items-start">
        <div class="w-3 h-3 bg-accent"></div>
        <h2 class="title text-left text-secondary">
          {content.title}
        </h2>
        <p set:html={content.subtitle} class="subtitle w-[80%] text-white"></p>
        <p set:html={content.description} class="paragraph w-[80%] text-white"></p>
      </div>

    </div>

    {/* Imagen Derecha - Al estar segundo en el HTML se renderiza ABAJO del contenido en móviles */}
    <div class="col-start-1 lg:col-start-3 lg:col-end-5 relative aspect-square xl:aspect-auto xl:h-[400px] lg:h-full z-20 js-animation-image w-full xl:w-auto">
      <div class="relative w-full h-full xl:absolute xl:inset-0">
        <img 
          class="w-full h-full object-cover object-center" 
          src={`/images/${content.image}.webp`} 
          alt={content.title} 
          width="640" 
          height="640" 
          decoding="async" 
          loading="lazy" 
        />
      </div>

    </div>

  </div>
</section>

<script>
  import { gsap, ScrollTrigger } from '../utils/animations';
  import { MEDIA_QUERIES } from '../utils/breakpoints';
  let servicesTriggers: any[] = [];

  const destroyServicesAnimation = () => {
    servicesTriggers.forEach(trigger => {
      if (trigger) trigger.kill(true);
    });
    servicesTriggers = [];

    const rows = document.querySelectorAll('.js-animation-section');
    rows.forEach(row => {
      const image = row.querySelector('.js-animation-image');
      const content = row.querySelector('.js-animation-text');
      if (image) gsap.set(image, { clearProps: "all" });
      if (content) gsap.set(content, { clearProps: "all" });
    });
  };

  const initServicesAnimation = () => {
    gsap.registerPlugin(ScrollTrigger);
    destroyServicesAnimation();

    const rows = document.querySelectorAll('.js-animation-section');
    let mm = gsap.matchMedia();

    rows.forEach((row) => {
      const image = row.querySelector('.js-animation-image') as HTMLElement;
      const content = row.querySelector('.js-animation-text') as HTMLElement;

      if (!image || !content) return;

      // ==========================================
      // 1. ESCRITORIO (730px en adelante) - Con PIN y Expansión completa
      // ==========================================
      mm.add(MEDIA_QUERIES.isDesktopPin, () => {
        const imageOrigin = "top right";
        const textXOffset = -100; 

        gsap.set(row, { position: "relative", overflow: "hidden" });
        
        const rect = image.getBoundingClientRect();
        const rowRect = row.getBoundingClientRect();
        
        const initialTop = rect.top - rowRect.top;
        const initialLeft = rect.left - rowRect.left;
        const initialWidth = rect.width;
        const initialHeight = rect.height;

        gsap.set(image, {
          position: "absolute",
          top: initialTop,
          left: initialLeft,
          width: initialWidth,
          height: initialHeight,
          aspectRatio: "auto"
        });

        gsap.set(image, { 
          scale: 0, 
          opacity: 0, 
          transformOrigin: imageOrigin 
        });
        
        gsap.set(content, { 
          opacity: 0, 
          xPercent: textXOffset 
        });

        const tl = gsap.timeline({
          scrollTrigger: {
            trigger: row,
            pin: true,
            pinSpacing: true, 
            start: "top top",          
            end: "+=2500", 
            scrub: 1,                 
            invalidateOnRefresh: true
          }
        });

        tl.to(image, { 
          opacity: 1, 
          scale: 1, 
          duration: 1, 
          ease: "none" 
        })
        .to(content, { 
          opacity: 1, 
          xPercent: 0, 
          duration: 0.7, 
          ease: "power1.out"
        }, "-=0.5")
        .addLabel('granExpansion', '+=0.1')
        .to(image, {
          top: 0,
          left: 0,
          width: "100%",
          height: "100%",
          duration: 1.5,
          ease: "power2.inOut"
        }, 'granExpansion')
        .to(row, {
          paddingTop: 0,
          paddingBottom: 0,
          duration: 1.5,
          ease: "power2.inOut"
        }, 'granExpansion')
        .to({}, { duration: 0.3 }); 

        if (tl.scrollTrigger) servicesTriggers.push(tl.scrollTrigger);
      });

      // ==========================================
      // 2. MÓVIL Y TABLET (729px hacia abajo) - SIN PIN, imagen crece al scrollear
      // ==========================================
      mm.add(MEDIA_QUERIES.isTabletMobileFlow, () => {
        // Estados iniciales nativos para móvil móviles
        gsap.set(image, { 
          scale: 0, 
          opacity: 0, 
          transformOrigin: "top right",
          force3D: true 
        });
        
        gsap.set(content, { 
          opacity: 0, 
          xPercent: -100,
          force3D: true 
        });

        const tlMobile = gsap.timeline({
          scrollTrigger: {
            trigger: row,
            start: "top 80%",   // Empieza a animar cuando asoma por abajo
            end: "bottom 80%",  // Termina de animar antes de salir de pantalla
            scrub: 1,           // Se mueve directo con la velocidad del scroll
            invalidateOnRefresh: true
          }
        });

        // La animación se va dando progresivamente según el scroll
        tlMobile.to(content, {
          opacity: 1,
          xPercent: 0,
          duration: 1,
          ease: "power1.out"
        },)
        .to( image, {
          opacity: 1,
          scale: 1,
          duration: 1.2,
          ease: "none" // 'none' para evitar tirones o saltos en mobile con el scrub
        }, "-=0.4"); // Se traslapan un poco para una transición muy orgánica

        if (tlMobile.scrollTrigger) servicesTriggers.push(tlMobile.scrollTrigger);
      });

    });

    ScrollTrigger.refresh();
  };

  document.addEventListener('DOMContentLoaded', initServicesAnimation);
  document.addEventListener('astro:page-load', initServicesAnimation);
  document.addEventListener('astro:before-swap', destroyServicesAnimation);
</script>