---
type Translations = typeof import('../i18n/en').default;
type InfoContent = Translations['services']['pool-construction']['info'];
interface Props {
  content: InfoContent;
}
const { content } = Astro.props as Props;
---
<section class="js-animation-content w-full h-screen bg-[#002127] overflow-hidden relative py-12 3xl:py-20">
  
  <div class="grid grid-cols-1 lg:grid-cols-[minmax(1.5rem,1fr)_minmax(0,640px)_minmax(0,640px)_minmax(1.5rem,1fr)] w-full h-full">
    
    {/* Contenido Izquierdo */}
    <div class="col-start-1 lg:col-start-2 lg:col-end-3 px-6 lg:px-0 flex flex-col justify-center h-full relative z-10 js-animation-content">
      
      <div class="w-full max-w-[640px] flex flex-col gap-6 items-start">
        <div class="w-3 h-3 bg-accent"></div>
        <h2 class="title text-left text-secondary">
          {content.title}
        </h2>
        <p set:html={content.subtitle} class="subtitle w-[80%] text-white"></p>
        <p set:html={content.description} class="paragraph w-[80%] text-white"></p>
      </div>

    </div>

    {/* Imagen Derecha */}
    <div class="col-start-1 lg:col-start-3 lg:col-end-5 relative h-[400px] lg:h-full z-20 js-animation-image" style="aspect-ratio: 1/1;">
      
      <div class="absolute inset-0 w-full h-full">
        <img 
          class="w-full h-full object-cover absolute inset-0 object-center" 
          src={`/images/${content.image}.webp`} 
          alt={content.title} 
          width="640" 
          height="640" 
          decoding="async" 
          loading="lazy" 
        />
      </div>

    </div>

  </div>
</section>

<script>
  import { gsap, ScrollTrigger } from '../utils/animations';

  let servicesTriggers: any[] = [];

  const destroyServicesAnimation = () => {
    servicesTriggers.forEach(trigger => {
      if (trigger) trigger.kill(true);
    });
    servicesTriggers = [];

    const rows = document.querySelectorAll('.js-animation-content');
    rows.forEach(row => {
      const image = row.querySelector('.js-animation-image');
      if (image) gsap.set(image, { clearProps: "all" });
    });
  };

  const initServicesAnimation = () => {
    gsap.registerPlugin(ScrollTrigger);
    destroyServicesAnimation();

    const rows = document.querySelectorAll('.js-animation-content');

    rows.forEach((row) => {
      const image = row.querySelector('.js-animation-image') as HTMLElement;
      const content = row.querySelector('.js-animation-content') as HTMLElement;

      if (!image || !content) return;

      const imageOrigin = "top right";
      const textXOffset = -80; 

      gsap.set(row, { position: "relative", overflow: "hidden" });
      
      const rect = image.getBoundingClientRect();
      const rowRect = row.getBoundingClientRect();
      
      const initialTop = rect.top - rowRect.top;
      const initialLeft = rect.left - rowRect.left;
      const initialWidth = rect.width;
      const initialHeight = rect.height;

      gsap.set(image, {
        position: "absolute",
        top: initialTop,
        left: initialLeft,
        width: initialWidth,
        height: initialHeight,
        aspectRatio: "auto"
      });

      gsap.set(image, { 
        scale: 0, 
        opacity: 0, 
        transformOrigin: imageOrigin 
      });
      
      gsap.set(content, { 
        opacity: 0, 
        x: textXOffset 
      });

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: row,
          pin: true,
          pinSpacing: true, 
          start: "top top",          
          end: "+=2500", 
          scrub: 1,                 
          invalidateOnRefresh: true
        }
      });

      tl.to(image, { 
        opacity: 1, 
        scale: 1, 
        duration: 1, 
        ease: "none" 
      })
      .to(content, { 
        opacity: 1, 
        x: 0, 
        duration: 0.7, 
        ease: "power1.out"
      }, "-=0.5")

      .addLabel('granExpansion', '+=0.1')
      
      .to(image, {
        top: 0,
        left: 0,
        width: "100%",
        height: "100%",
        duration: 1.5,
        ease: "power2.inOut"
      }, 'granExpansion')
      
      .to(row, {
        paddingTop: 0,
        paddingBottom: 0,
        duration: 1.5,
        ease: "power2.inOut"
      }, 'granExpansion')

      // === NUEVO: TIEMPO DE ESPERA ===
      // Crea una pausa artificial al final para mantener la imagen a pantalla completa mientras se scrollea
      // Puedes subir este 'duration' (ej: 1.5 o 2.0) si quieres que tarde aún más en avanzar.
      .to({}, { duration: 0.3 }); 

      if (tl.scrollTrigger) servicesTriggers.push(tl.scrollTrigger);
    });

    ScrollTrigger.refresh();
  };

  document.addEventListener('DOMContentLoaded', initServicesAnimation);
  document.addEventListener('astro:page-load', initServicesAnimation);
  document.addEventListener('astro:before-swap', destroyServicesAnimation);
</script>