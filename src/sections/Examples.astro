---
type Translations = typeof import('../i18n/en').default;
type ExamplesContent = Translations['services']['pool-construction']['examples'];
interface Props {
  content: ExamplesContent;
}
const { content } = Astro.props as Props;
---
<section class="w-full bg-white flex justify-center items-center">
  <div class="container-full flex flex-col justify-center items-start py-20 gap-6">
    <div class="flex flex-col justify-center items-start gap-6">
      <h2 set:html={content.title} class="text-primary title-sm text-left"></h2>
      <p set:html={content.description} class="text-paragraph paragraph"></p>
    </div>
    <div class="w-full grid grid-cols-2 justify-center items-start gap-6">
      {
        content.items.map((item)=>( 
          <div class="flex flex-col justify-center items-start gap-6">
            <div class="w-full h-auto relative" style="aspect-ratio: 628/414;">
              <img 
                class="w-full h-full object-cover object-center absolute inset-0" 
                src={`/images/${item.image}.webp`} 
                alt={item.title} 
                width="628" 
                height="414" 
                decoding="async" 
                loading="lazy" 
              />
            </div>
            <h3 class="text-primary subtitle-dark uppercase">
              {item.title}
            </h3>
            <p set:html={item.description} class="text-paragraph paragraph"></p>
            <ul class="flex flex-col justify-start items-start gap-2">
              {
                item.list.map((feature) => (
                  <li class="text-paragraph paragraph list-disc list-inside">
                    {feature}
                  </li>
                ))
              }
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>