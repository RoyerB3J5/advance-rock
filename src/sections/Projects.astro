---
type Translations = typeof import("../i18n/en").default;
type ProjectsContent = Translations["main"]["projects"];
interface Props {
  content: ProjectsContent;
}
const { content } = Astro.props as Props;
const R2_BASE = import.meta.env.PUBLIC_R2_URL;
---
<section id="fleet-section" class="w-full flex flex-col  justify-center items-center pt-16  xl:pt-12 3xl:pt-20 pb-4 xl:pb-8.5 h-auto xl:h-screen 3xl:h-auto bg-white overflow-hidden relative z-10">
  <div  class="container-full flex flex-col xl:flex-row justify-center items-center xl:items-stretch gap-6 h-full">
    <div class="h-auto xl:h-full w-full xl:w-auto 3xl:w-[52%] 3xl:h-autojs-panel-growth overflow-hidden relative" style="aspect-ratio: 628/740;">
      <video
        autoplay
        loop
        muted
        playsinline
        controlslist="nodownload no remoteplayback"
        disablepictureinpicture
        oncontextmenu="return false;"
        class="absolute inset-0 w-full h-full object-cover pointer-events-none object-center"
      >
        <source src={`${R2_BASE}/videos/Flota_moderna.mp4`} type="video/mp4" />
      </video>
    </div>
    <div class="w-full xl:w-[48%]  flex flex-col justify-between items-start grow gap-6">
      <div class="flex flex-col justify-center items-start gap-6 js-content-block-1">
        <h2 class="text-primary title-sm">{content.first.title}</h2>
        <p class="text-paragraph paragraph">{content.first.description}</p>
      </div>
      <div class="flex flex-col justify-center items-start gap-6 js-content-block-2">
        <div class="w-full xl:w-[50%] 3xl:w-[60%] h-auto relative" style="aspect-ratio: 382/215;">
          <img src="/images/modern.webp" alt="Moder Advance" class="w-full h-full object-cover absolute inset-0 object-center js-image-growth" width="382" height="215" decoding="async" loading="lazy"/>
        </div>
        <p class="text-paragraph paragraph js-fade-left-p w-full xl:w-[70%] 3xl:w-[90%]">{content.first.description2}</p>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap, ScrollTrigger } from '../utils/animations';

  document.addEventListener('DOMContentLoaded', () => {
    // Registramos el plugin ScrollTrigger
    gsap.registerPlugin(ScrollTrigger);

    const section = document.querySelector('#fleet-section');
    if (!section) return;

    // Buscamos los elementos con selectores JS dedicados
    const panelGrowth  = section.querySelector('.js-panel-growth');
    const contentBlock1 = section.querySelector('.js-content-block-1');
    const imageGrowth   = section.querySelector('.js-image-growth');
    const fadeLeftP     = section.querySelector('.js-fade-left-p');

    // Validación estricta
    if (!panelGrowth || !contentBlock1 || !imageGrowth || !fadeLeftP) {
      console.warn('Faltan elementos en el DOM para iniciar la animación de GSAP en la sección Fleet');
      return;
    }

    // 1. Preparación de estados iniciales
    gsap.set(panelGrowth, { opacity: 0, scale: 0, transformOrigin: "top left" });
    gsap.set(contentBlock1, { opacity: 0, x: 700 });
    gsap.set(fadeLeftP, { opacity: 0, x: 700 });
    gsap.set(imageGrowth, { opacity: 0, scale: 0, transformOrigin: "top left" });

    // 2. Timeline SÍNCRONO con el Scroll (Scrub + Pin)
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: "top 80%",         
        end: () => window.innerWidth < 768 ? "+=800" : "+=500",            
        scrub: 1,                 
        invalidateOnRefresh: true 
      }
    });

    // FASE 1: El Panel Turquesa empieza a crecer (Tiempo: 0.0s a 1.0s)
    tl.to(panelGrowth, { 
      opacity: 1, 
      scale: 1, 
      duration: 1, 
      ease: "none" 
    })

    .to(contentBlock1, { 
      opacity: 1, 
      x: 0, 
      duration: 0.8, 
      ease: "power2.inOut", 
      immediateRender: false 
    }, "-=0.8")

    // FASE 3: ¡EL CAMBIO AQUÍ! 
    // Forzamos a la imagen a aparecer en el segundo 0.75 de la animación.
    // Como 0.75 es menor que 1.0, el panel turquesa todavía estará creciendo (al 75%).
    // Esto crea un solapamiento perfecto y continuo de elementos saliendo a escena.
    .to(imageGrowth, { 
      opacity: 1, 
      scale: 1, 
      duration: 0.8, 
      ease: "none"
    }, 0.55) // <--- El número mágico absoluto controla este inicio temprano

    // El párrafo entra al mismo tiempo que la imagen (<) de la Fase 3
    .to(fadeLeftP, { 
      opacity: 1, 
      x: 0, 
      duration: 0.8, 
      ease: "power2.inOut" 
    }, "<");
    
  });
</script>