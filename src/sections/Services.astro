---
import Button from "../components/Button.astro";
import type { Language } from '../types/language.type';
type Translations = typeof import("../i18n/en").default;
type ServicesContent = Translations["main"]["services"];
interface Props {
  content: ServicesContent;
}
const { content } = Astro.props as Props;

// Se añadieron las variantes `[&.is-active]:bg-...` para que el click también pinte el fondo en móvil
const colorContent = [
  {
    box:'bg-accent',
    textTitle:'text-white',
    textDescription:'text-white',
    textButton:'text-white',
    background:'bg-transparent hover:bg-primary/90 [&.is-active]:bg-primary/90'
  },
  {
    box:'bg-primary',
    textTitle:'text-white',
    textDescription:'text-white',
    textButton:'text-white',
    background:'bg-transparent hover:bg-accent/90 [&.is-active]:bg-accent/90'
  },
  {
    box:'bg-accent',
    textTitle:'text-white',
    textDescription:'text-white',
    textButton:'text-white',
    background:'bg-transparent hover:bg-secondary/90 [&.is-active]:bg-secondary/90'
  },
  {
    box:'bg-primary',
    textTitle:'text-primary',
    textDescription:'text-paragraph',
    textButton:'text-paragraph',
    background:'bg-transparent hover:bg-white/90 [&.is-active]:bg-white/90'
  },
  {
    box:'bg-accent',
    textTitle:'text-white',
    textDescription:'text-white',
    textButton:'text-white',
    background:'bg-transparent hover:bg-black/90 [&.is-active]:bg-black/90'
  },
  {
    box:'bg-white',
    textTitle:'text-white',
    textDescription:'text-white',
    textButton:'text-white',
    background:'bg-transparent hover:bg-primary/90 [&.is-active]:bg-primary/90'
  }
]
const lang = Astro.params.lang as Language;
---
<section data-scroll-snap class="relative w-full h-auto xl:h-screen overflow-hidden">
  <img src='/images/services.webp' class="w-full h-full absolute object-cover object-[50%_80%] inset-0" width="2100" height="1313" decoding="async" loading="lazy"/>
  <div class="absolute w-full h-full bg-black/30"></div>
  <div class="w-full h-full grid grid-cols-2 xl:grid-cols-4 grid-rows-2 justify-center items-center relative">
    <div class="col-span-2 h-full px-4 py-9 xl:p-20 flex flex-col justify-center items-start gap-6 text-white">
      <h2 class="title">
        {content.title}
      </h2>
      <p class="text-[20px] font-paragraph leading-[150%] font-normal hidden md:block" set:html={content.description}>
      </p>
      <Button
        text={content.button.label}
        href={content.button.href}
        textClass="text-[19x]"
      />
    </div>
    {
      content.items.map((item,index)=>( 
        /* Se añade la clase 'js-service-card' para JavaScript y las variantes '[&.is-active]:' para el contenedor padre */
        <div class={`js-service-card w-full h-full flex flex-col hover:justify-between hover:items-start [&.is-active]:justify-between [&.is-active]:items-start items-start xl:items-end justify-end py-4 xl:py-20 px-4 xl:px-10 border border-white/25 group min-h-[210px] xl:min-h-0 ${colorContent[index].background} transition-all duration-300 ease-in-out cursor-pointer`}>
          
          {/* Se añade la variante 'group-[.is-active]:flex' y 'group-[.is-active]:opacity-100' */}
          <div class="group-hover:flex group-[.is-active]:flex flex-col justify-center items-start gap-2 xl:gap-6 hidden transition-all duration-300 ease-in-out opacity-0 group-hover:opacity-100 group-[.is-active]:opacity-100">
            <div class={`w-3 h-3 ${colorContent[index].box }`}></div>
            <h3 class={`text-[24px] md:text-[32px] xl:text-[40px] font-paragraph font-bold leading-[110%] ${colorContent[index].textTitle}`}>{item.title}</h3>
            <p class={`${colorContent[index].textDescription} paragraph`}>{item.description}</p>
          </div>
          
          {/* Se añade la variante 'group-[.is-active]:inline-block' y 'group-[.is-active]:opacity-100' */}
          <a href={`/${lang}/services${item.button.href}`} class={`paragraph-bold ${colorContent[index].textButton} button-decoration hidden group-hover:inline-block group-[.is-active]:inline-block transition-all duration-300 ease-in-out opacity-0 group-hover:opacity-100 group-[.is-active]:opacity-100`}>
            {item.button.label}
          </a>
          
          {/* Se añade la variante 'group-[.is-active]:hidden' y 'group-[.is-active]:opacity-0' */}
          <p class="text-[20px] font-paragraph leading-[150%] font-normal group-hover:hidden group-[.is-active]:hidden transition-all duration-300 ease-in-out text-white opacity-100 group-hover:opacity-0 group-[.is-active]:opacity-0">
            {item.first}
          </p>
        </div>
      ))
    }
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const cards = document.querySelectorAll('.js-service-card');

    cards.forEach(card => {
      card.addEventListener('click', (e) => {
        // Si la pantalla es de escritorio (mayor a 1280px), dejamos que funcione el hover nativo
        if (window.innerWidth > 1280) return;

        const isActive = card.classList.contains('is-active');
        const clickedLink = (e.target as HTMLElement).closest('a');

        // Si la tarjeta ya está activa Y el usuario clickeó el botón de redirección, permitimos la navegación nativa
        if (isActive && clickedLink) {
          return; 
        }

        // En cualquier otro caso en móvil, prevenimos comportamientos extraños y controlamos el estado
        e.preventDefault();

        // Cerramos todas las demás tarjetas abiertas para que solo haya una activa a la vez
        cards.forEach(c => {
          if (c !== card) c.classList.remove('is-active');
        });

        // Alternamos el estado de la tarjeta clickeada
        card.classList.toggle('is-active');
      });
    });
  });
</script>