---
type Translations = typeof import("../i18n/en").default;
type InformationContent = Translations["main"]["information"];
interface Props {
  content: InformationContent;
}
const { content } = Astro.props as Props;
---
<section data-scroll-snap class="w-full">
  <div id="information-animated-section" class="relative w-full h-screen overflow-hidden bg-white">
    
    <div class="js-white-panel absolute top-0 right-0 w-[62%] h-full flex flex-col justify-between items-end z-10 bg-white pr-[max(2rem,calc(50vw-640px))] py-10 3xl:py-20">
      <div class="flex flex-col justify-center items-start gap-6 max-w-[519px]">
        <h2 set:html={content.third.title} class="title text-accent"></h2>
        <p class="subtitle text-paragraph">{content.third.para1}</p>
        <p class="paragraph text-paragraph">{content.third.para2}</p>
        <a href="#" class="text-paragraph paragraph-bold flex justify-start items-center gap-2">
          <p>{content.third.link}</p>
          <img src="/images/arrow.svg" width="16" height="16" decoding="async" loading="lazy" class="w-4 h-4" alt="Arrow Right"/>
        </a>
      </div>
      <div class="grid grid-cols-4 justify-center items-center gap-4">
        {
          content.third.items.map((item)=>( 
            <div class="flex flex-col justify-start items-start gap-2 p-4 rounded-[4px] border border-[#D9D9D9] max-w-[170px]">
              <h3 class="text-primary paragraph-bold">{item.title}</h3>
              <p class="text-paragraph paragraph" set:html={item.description}></p>
            </div>
          ))
        }
      </div>
    </div>

    <div class="js-dark-panel absolute top-0 left-0 w-[60%] h-full flex flex-col z-20">
      <div class="w-full h-[70%] 3xl:h-[67%] bg-[#001f24] flex flex-col justify-start pl-[max(2rem,calc(50vw-640px))] py-20">
        <div class="flex flex-col justify-start items-start gap-6 w-[70%] js-anim-text-block">
          <h2 class="text-white title" set:html={content.first.title}></h2>
          <p class="text-white subtitle w-[80%]">{content.first.description}</p>
        </div>
      </div>
      <div class="w-full h-[30%] 3xl:h-[33%] bg-[#002b31] flex justify-start items-center pl-[max(2rem,calc(50vw-640px))] py-20">
        <div class="grid grid-cols-2 gap-x-8 gap-y-6 w-full text-white js-anim-grid">
          {
            content.second.map((item)=>( 
              <div class="flex justify-start items-start gap-2">
                <img src="/images/check.svg" width="24" height="24" decoding="async" loading="lazy" class="w-6 h-6" alt="Check"/>
                <div class="flex flex-col justify-center items-start ">
                  <h3 class="paragraph-bold">{item.title}</h3>
                  <p class="paragraph">{item.description}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <div class="js-blue-panel absolute top-0 left-[60%] w-[40%] h-full bg-[#00a3c4] z-30">
      
      <img 
        src="/images/camion.webp" 
        alt="Camión" 
        class="js-anim-camion absolute top-[2%] 3xl:top-[3%] right-[-65%] w-[190%] h-auto max-w-none pointer-events-none"
        width="2752" height="1156" decoding="async" loading="lazy" 
      />

      <div class="absolute bottom-20 w-full px-[max(2rem,calc(50vw-640px))] pointer-events-none">
        <div class="relative w-full h-[114px] js-logo-track">
          <img 
            src="/images/logo-small-2.svg" 
            width="117" height="114" decoding="async" loading="lazy" 
            class="js-anim-logo absolute top-0 right-0 w-[117px] h-[114px] pointer-events-auto" 
            alt="Logo"
          />
        </div>
      </div>

    </div>

  </div>
</section>

<script>
  import { gsap } from '../utils/animations';

  document.addEventListener('DOMContentLoaded', () => {
    const section = document.querySelector('#information-animated-section');
    if (!section) return;

    const textBlock  = section.querySelector('.js-anim-text-block');
    const camion     = section.querySelector('.js-anim-camion');
    const grid       = section.querySelector('.js-anim-grid');
    const logoImg    = section.querySelector('.js-anim-logo'); 
    const logoTrack  = section.querySelector('.js-logo-track');
    const darkPanel  = section.querySelector('.js-dark-panel');
    const whitePanel = section.querySelector('.js-white-panel');
    const bluePanel  = section.querySelector('.js-blue-panel');

    if (!textBlock || !camion || !grid || !logoImg || !logoTrack || !darkPanel || !whitePanel || !bluePanel) {
      console.warn('Faltan elementos en el DOM para iniciar GSAP');
      return;
    }

    // 1. Preparación de estados iniciales
    gsap.set([grid, logoImg], { opacity: 0, y: 50 });
    gsap.set(camion, { opacity: 0, x: 150 });
    gsap.set(textBlock, { opacity: 0, x: -150 });
    gsap.set(whitePanel, { xPercent: 100 });

    // 2. Timeline atado a ScrollTrigger con scrub
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: "top top",
        end: "+=1500",
        pin: true,
        scrub: 1,
        invalidateOnRefresh: true
      }
    });

    // FASE 1: Animación de entrada (Mantenemos power2.out para adelantarse sutilmente al scroll)
    tl.to(textBlock, { opacity: 1, x: 0, duration: 1, ease: "power2.out", immediateRender: false })
      .to(camion,    { opacity: 1, x: 0, duration: 1, ease: "power2.out", immediateRender: false }, "<")
      .to({}, { duration: 0.5 })
      .to(grid, { opacity: 1, y: 0, duration: 1, ease: "power2.out", immediateRender: false })
      .to(logoImg, { opacity: 1, y: 0, duration: 1, ease: "power2.out", immediateRender: false }, "<");

    tl.to({}, { duration: 0.5 }); // Pausa de lectura

    // FASE 2: Transición de Paneles y Movimiento (Cambiado a ease: "none" para respuesta directa al scroll)
    tl.add("slide");

    tl.to(darkPanel, { xPercent: -100, duration: 2, ease: "none" }, "slide")
      .to(bluePanel, { left: "0%", width: "38%", duration: 2, ease: "none" }, "slide")
      .to(whitePanel, { xPercent: 0, duration: 2, ease: "none" }, "slide");

    // Mover camión de forma lineal con el scroll
    tl.to(camion, { 
      right: "auto", 
      left: "-65%",  
      duration: 2, 
      ease: "none" 
    }, "slide");

    // Desplazamiento del logo por carril (Sincronía perfecta al scroll)
    tl.to(logoImg, {
      x: () => {
        return -((logoTrack as HTMLElement).offsetWidth - 117); 
      },
      duration: 2,
      ease: "none"
    }, "slide")
    .to({}, { duration: 0.3 }); 
  });
</script>