---
type Translations = typeof import("../i18n/en").default;
type InformationContent = Translations["main"]["information"];
interface Props {
  content: InformationContent;
}
const { content } = Astro.props as Props;
---
<section data-scroll-snap class="w-full">
  <div id="information-animated-section" class="relative w-full h-auto xl:h-screen overflow-hidden bg-white flex flex-col justify-center items-center xl:block">
    <div class="js-dark-panel relative xl:absolute top-0 left-0 w-full xl:w-[60%] h-full flex flex-col z-20">
      <div class="w-full h-auto xl:h-[70%] 3xl:h-[67%] bg-[#001f24] flex flex-col justify-start xl:pl-[max(2rem,calc(50vw-640px))] pt-16 xl:py-20 pb-[35vh] xl:pb-0 relative">
        <img 
          src="/images/camion.webp" 
          alt="Camión" 
          class="js-anim-camion absolute right-[-75%] bottom-8  w-[140%] md:w-[100%]  h-auto max-w-none pointer-events-none block xl:hidden"
          width="2752" height="1156" decoding="async" loading="lazy" 
        />
        <div class="flex flex-col justify-start items-start gap-6 w-full xl:w-[70%] js-anim-text-block px-4 xl:px-0">
          <h2 class="text-white title" set:html={content.first.title}></h2>
          <p class="text-white subtitle w-full xl:w-[80%]">{content.first.description}</p>
        </div>
      </div>
      <div class="w-full h-full xl:h-[30%] 3xl:h-[33%] bg-[#002b31] flex justify-start items-center xl:pl-[max(2rem,calc(50vw-640px))] py-6 xl:py-20 px-4 xl:px-0 ">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6 w-full text-white js-anim-grid">
          {
            content.second.map((item)=>( 
              <div class="flex justify-start items-start gap-2 js-anim-grid-item">
                <img src="/images/check.svg" width="24" height="24" decoding="async" loading="lazy" class="w-6 h-6" alt="Check"/>
                <div class="flex flex-col justify-center items-start ">
                  <h3 class="paragraph-bold">{item.title}</h3>
                  <p class="paragraph">{item.description}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <div class="js-blue-panel relative xl:absolute xl:top-0 xl:left-[60%] w-full xl:w-[40%] h-full bg-[#00a3c4] z-30 py-8 xl:py-30 flex flex-col justify-end items-end min-h-[35vh] xl:min-h-auto">
      
      <img 
        src="/images/camion.webp" 
        alt="Camión" 
        class="js-anim-camion absolute left-[40%] xl:left-auto top-8 xl:top-[2%] 3xl:top-[3%] xl:right-[-65%] w-[140%] md:w-[100%] xl:w-[190%] h-auto max-w-none pointer-events-none"
        width="2752" height="1156" decoding="async" loading="lazy" 
      />

      <div class="relative xl:absolute xl:bottom-20 w-full xl:px-[max(2rem,calc(50vw-640px))] pointer-events-none px-4 xl:px-0">
        <div class="relative w-full h-16 xl:h-[114px] js-logo-track">
          <img 
            src="/images/logo-small-2.svg" 
            width="117" height="114" decoding="async" loading="lazy" 
            class="js-anim-logo absolute top-0 right-0 h-16 w-auto xl:w-[117px] xl:h-[114px] pointer-events-auto" 
            alt="Logo"
          />
        </div>
      </div>
    </div>
    <div class="js-white-panel relative xl:absolute xl:top-0 xl:right-0 w-full xl:w-[62%] h-full flex flex-col justify-center xl:justify-between items-center xl:items-end z-10 bg-white px-4 xl:pr-[max(2rem,calc(50vw-640px))] py-16 xl:py-10 3xl:py-20 gap-8 xl:gap-0">
      <div class="flex flex-col justify-center items-start gap-6 xl:max-w-[519px]">
        <h2 set:html={content.third.title} class="title text-accent order-2 xl:order-1 js-content-white"></h2>
        <p class="subtitle text-paragraph order-1 xl:order-2 js-content-white ">{content.third.para1}</p>
        <p class="paragraph text-paragraph order-3 js-content-white">{content.third.para2}</p>
        <a href="#" class=" flex justify-start items-center gap-2 order-4 js-content-white">
          <p class='text-[#002E36] paragraph-bold'>{content.third.link}</p>
          <img src="/images/arrow.svg" width="16" height="16" decoding="async" loading="lazy" class="w-4 h-4" alt="Arrow Right"/>
        </a>
      </div>
      <div class="grid grid-cols-1 xl:grid-cols-4 justify-center items-center gap-6 xl:gap-4 w-full xl:w-auto">
        {
          content.third.items.map((item)=>( 
            <div class="flex flex-col justify-start items-start gap-2 px-4 py-2 xl:p-4 rounded-0 xl:rounded-[4px] border border-[#D9D9D9] max-w-none xl:max-w-[170px] js-content-white-item">
              <h3 class="text-primary paragraph-bold">{item.title}</h3>
              <p class="text-paragraph paragraph" set:html={item.description}></p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from '../utils/animations';
  import { MEDIA_QUERIES } from '../utils/breakpoints';

  document.addEventListener('DOMContentLoaded', () => {
    const section = document.querySelector('#information-animated-section');
    if (!section) return;

    const textBlock  = section.querySelector('.js-anim-text-block');
    const grid       = section.querySelector('.js-anim-grid');
    const logoImg    = section.querySelector('.js-anim-logo'); 
    const logoTrack  = section.querySelector('.js-logo-track');
    const darkPanel  = section.querySelector('.js-dark-panel');
    const whitePanel = section.querySelector('.js-white-panel');
    const bluePanel  = section.querySelector('.js-blue-panel');

    const camiones = section.querySelectorAll('.js-anim-camion');
    const camionEscritorio = camiones[1] || camiones[0]; 

    if (!textBlock || camiones.length === 0 || !grid || !logoImg || !logoTrack || !darkPanel || !whitePanel || !bluePanel) {
      console.warn('Faltan elementos en el DOM para iniciar GSAP');
      return;
    }

    // ==========================================
    // SOLUCIÓN AL PROBLEMA DE ORDER:
    // Convertimos a Array y ordenamos según el CSS real de la pantalla actual
    // ==========================================
    const obtenerElementosOrdenados = (selector: string) => {
      return Array.from(section.querySelectorAll(selector)).sort((a, b) => {
        const orderA = parseInt(window.getComputedStyle(a).order) || 0;
        const orderB = parseInt(window.getComputedStyle(b).order) || 0;
        return orderA - orderB;
      });
    };

    let mm = gsap.matchMedia();

    // ==========================================
    // 1. ESCRITORIO (730px en adelante)
    // ==========================================
    mm.add(MEDIA_QUERIES.isDesktopPin, () => {
      // Obtenemos los elementos ordenados visualmente para escritorio
      const whiteContents = obtenerElementosOrdenados('.js-content-white');

      gsap.set([grid, logoImg], { opacity: 0, y: 50 });
      gsap.set(camionEscritorio, { opacity: 0, x: 150 });
      gsap.set(textBlock, { opacity: 0, xPercent: -100 });
      gsap.set(whitePanel, { xPercent: 100 });

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: "top top",
          end: "+=1500",
          pin: true,
          scrub: 1,
          invalidateOnRefresh: true
        }
      });

      tl.to(textBlock, { opacity: 1, xPercent: 0, duration: 1, ease: "power2.out", immediateRender: false })
        .to(camionEscritorio, { opacity: 1, x: 0, duration: 1, ease: "power2.out", immediateRender: false }, "<")
        .to({}, { duration: 0.5 })
        .to(grid, { opacity: 1, y: 0, duration: 1, ease: "power2.out", immediateRender: false })
        .to(logoImg, { opacity: 1, y: 0, duration: 1, ease: "power2.out", immediateRender: false }, "<");

      tl.to({}, { duration: 0.5 });

      tl.add("slide");
      tl.to(darkPanel, { xPercent: -100, duration: 2, ease: "none" }, "slide")
        .to(bluePanel, { left: "0%", width: "38%", duration: 2, ease: "none" }, "slide")
        .to(whitePanel, { xPercent: 0, duration: 2, ease: "none" }, "slide");

      tl.to(camionEscritorio, { right: "auto", left: "-65%", duration: 2, ease: "none" }, "slide");

      tl.to(logoImg, {
        x: () => -((logoTrack as HTMLElement).offsetWidth - 117),
        duration: 2,
        ease: "none"
      }, "slide")
      .to({}, { duration: 0.3 }); 
    });

    // ==========================================
    // 2. MÓVIL Y TABLET (729px hacia abajo)
    // ==========================================
    mm.add(MEDIA_QUERIES.isTabletMobileFlow, () => {
      const camion1 = camiones[0]; 
      const camion2 = camiones[1]; 
      const gridItems = section.querySelectorAll('.js-anim-grid-item');
      const whiteItems = section.querySelectorAll('.js-content-white-item');

      // Obtenemos los elementos ordenados visualmente para móvil (Subtítulo -> Título -> Párrafo -> Link)
      const whiteContents = obtenerElementosOrdenados('.js-content-white');

      // Estados iniciales preparados
      gsap.set(textBlock, { opacity: 0, xPercent: -100 });
      if (camion1) gsap.set(camion1, { xPercent: 100 }); 
      if (camion2) gsap.set(camion2, { opacity: 0, xPercent: 100 }); 
      gsap.set(gridItems, { opacity: 0, xPercent: -100 });
      gsap.set(logoImg, { opacity: 0, xPercent: 100 });
      gsap.set(whiteContents, { opacity: 0, xPercent: -100 });
      gsap.set(whiteItems, { opacity: 0, xPercent: 100 });

      const tlMobile = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: "top 80%",
          end: "+=1800", 
          scrub: 1
        }
      });

      // 1. Text Block
      tlMobile.to(textBlock, { opacity: 1, xPercent: 0, duration: 0.8, ease: "power2.inOut" });

      // 2. Primer Camión
      if (camion1) {
        tlMobile.to(camion1, { xPercent: 0, duration: 1.5, ease: "power2.out" })       
                .to({}, { duration: 1 })                                             
                .to(camion1, { xPercent: () => window.innerWidth >= 730 ? -150 : -90, duration: 3.5, ease: "none" }, "+=0.2");    
      }

      // 3. Grid Items
      if (gridItems.length > 0) {
        tlMobile.to(gridItems, { opacity: 1, xPercent: 0, duration: 1, ease: "power2.inOut", stagger: 0.2 });
      }

      // 4. Segundo Camión
      if (camion2) {
        tlMobile.to(camion2, { opacity: 1, xPercent: 0, duration: 1.5, ease: "power2.out" }) 
                .to({}, { duration: 0.5 })                                                   
                .to(camion2, { xPercent: -90, duration: 3.5, ease: "power2.in" });           
      }
      tlMobile.to(logoImg, { opacity: 1, xPercent: 0, duration: 0.8, ease: "power2.inOut" }, "<");

      // 6. Elementos js-content-white (¡AHORA SÍ RESPETA EL STAGGER VISUAL!)
      if (whiteContents.length > 0) {
        tlMobile.to(whiteContents, { opacity: 1, xPercent: 0, duration: 1, ease: "power2.inOut", stagger: 0.2 });
      }

      // 7. Cada js-content-white-item
      if (whiteItems.length > 0) {
        tlMobile.to(whiteItems, { opacity: 1, xPercent: 0, duration: 1.2, ease: "power2.inOut", stagger: 0.2 });
      }
    });
  });
</script>