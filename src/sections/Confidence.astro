---
import Button from "../components/Button.astro";
type Translations = typeof import("../i18n/en").default;
type ConfidenceContent = Translations["main"]["confidence"];
interface Props {
  content: ConfidenceContent;
}
const { content } = Astro.props as Props;
---
<section data-scroll-snap id="confidence-section" class="w-full h-screen flex flex-col justify-center items-center gap-6 bg-primary-back relative z-10 overflow-hidden js-confidence-section py-12 3xl:py-20">  
  <div class="grid grid-cols-1 lg:grid-cols-[minmax(1.5rem,1fr)_minmax(0,640px)_minmax(0,640px)_minmax(1.5rem,1fr)] w-full h-full">
    {/* Contenido Izquierdo */}
    <div class="col-start-1 lg:col-start-2 lg:col-end-3 px-6 lg:px-0 flex flex-col justify-center h-full relative z-10 js-confidence-content">
      <div class="w-full max-w-[640px] flex flex-col gap-6 items-start">
        <h2 class='title text-secondary  font-bold text-start' set:html={content.title1}> </h2>
        <div class="flex flex-col justify-center items-start gap-6 js-content z-20"> 
          <p class="subtitle text-white">{content.description}</p>
          <p class="paragraph text-white text-start"  set:html={content.description2}></p>
          <Button
              text={content.button.label}
              href={content.button.href}
              textClass="text-[17px]"
            />
        </div>
      </div>
    </div>
    {/* Imagen Derecha */}
    <div class="col-start-1 lg:col-start-3 lg:col-end-5 relative h-[400px] w-auto lg:h-full z-20 js-confidence-image" style="aspect-ratio: 1/1;">
      <div class="absolute inset-0 w-full h-full">
        <img src={`/images/${content.img}.webp`} class="absolute w-full h-full object-cover object-center inset-0" width="2200" height="1228" decoding="async" loading="lazy"/>
      </div>
    </div>
  </div> 
</section>
<script>
  import { gsap, ScrollTrigger } from '../utils/animations';

  let servicesTriggers: any[] = [];

  const destroyServicesAnimation = () => {
    servicesTriggers.forEach(trigger => {
      if (trigger) trigger.kill(true);
    });
    servicesTriggers = [];

    const rows = document.querySelectorAll('.js-confidence-section');
    rows.forEach(row => {
      const image = row.querySelector('.js-confidence-image');
      if (image) gsap.set(image, { clearProps: "all" });
    });
  };

  const initServicesAnimation = () => {
    gsap.registerPlugin(ScrollTrigger);
    destroyServicesAnimation();

    const rows = document.querySelectorAll('.js-confidence-section');

    rows.forEach((row) => {
      const image = row.querySelector('.js-confidence-image') as HTMLElement;
      const content = row.querySelector('.js-confidence-content') as HTMLElement;

      if (!image || !content) return;

      const imageOrigin = "top right";

      gsap.set(row, { position: "relative", overflow: "hidden" });
      
      const rect = image.getBoundingClientRect();
      const rowRect = row.getBoundingClientRect();
      
      const initialTop = rect.top - rowRect.top;
      const initialLeft = rect.left - rowRect.left;
      const initialWidth = rect.width;
      const initialHeight = rect.height;

      gsap.set(image, {
        position: "absolute",
        top: initialTop,
        left: initialLeft,
        width: initialWidth,
        height: initialHeight,
        aspectRatio: "auto"
      });

      gsap.set(image, { 
        scale: 0, 
        opacity: 0, 
        transformOrigin: imageOrigin 
      });
      
      gsap.set(content, { 
        opacity: 0, 
        xPercent: -100 
      });

      // 1. CALCULAMOS LAS DISTANCIAS REALES DE SCROLL
      // Distancia desde que asoma la sección (80%) hasta que se pega arriba (0%)
      const introDistance = window.innerHeight * 0.75; 
      // Los píxeles que durará congelada arriba haciendo la gran expansión
      const pinDistance = 3500; 

      const pinTrigger = ScrollTrigger.create({
        trigger: row,
        start: "top top",
        pin: true,
        pinSpacing: true,
        end: `+=${pinDistance}`,
        invalidateOnRefresh: true
      });
      if (pinTrigger) servicesTriggers.push(pinTrigger);

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: row,
          start: "top 75%",
          end: `+=${introDistance + pinDistance}`, // El recorrido total combinando ambos
          scrub: 1,                 
          invalidateOnRefresh: true
        }
      });

      // TRUCO PRO: Al usar 'scrub', si usamos las distancias en píxeles como "duration",
      // la animación se sincronizará perfectamente con la velocidad del scroll del usuario.

      // --- FASE 1: Animación de entrada (Se ejecuta mientras la sección sube de 80% a 0%) ---
      tl.to(image, { 
        opacity: 1, 
        scale: 1, 
        duration: introDistance * 0.5, // Ocupa la mitad del trayecto de entrada
        ease: "none" 
      })
      .to(content, { 
        opacity: 1, 
        xPercent: 0, 
        duration: introDistance * 0.5, // Ocupa la otra mitad
        ease: "power2.out"
      }, `-=${introDistance * 0.1}`) // Un pequeño solapamiento para fluidez

      // --- FASE 2: Gran Expansión (Empieza justo en el píxel donde la sección se clava en "top top") ---
      // Colocamos una etiqueta exactamente en la posición de 'introDistance'
      .addLabel('granExpansion', introDistance)
      
      .to(image, {
        top: 0,
        left: 0,
        width: "100%",
        height: "100%",
        duration: pinDistance, // Se expande a lo largo de los 2500px que dura el Pin
        ease: "power2.inOut"
      }, 'granExpansion')
      
      .to(row, {
        paddingTop: 0,
        paddingBottom: 0,
        duration: pinDistance,
        ease: "power2.inOut"
      }, 'granExpansion')

      .to({}, { duration: pinDistance * 0.1 }); // Un pequeño respiro de scroll al final

      if (tl.scrollTrigger) servicesTriggers.push(tl.scrollTrigger);
    });

    ScrollTrigger.refresh();
  };

  document.addEventListener('DOMContentLoaded', initServicesAnimation);
  document.addEventListener('astro:page-load', initServicesAnimation);
  document.addEventListener('astro:before-swap', destroyServicesAnimation);
</script>