---
type Translations = typeof import("../i18n/en").default;
type ProjectsContent = Translations["main"]["projects"];
interface Props {
  content: ProjectsContent;
}
const { content } = Astro.props as Props;
---
<section id="fleet-section-2" class="w-full flex flex-col justify-center items-center pb-16 xl:pb-12 3xl:pb-20 pt-4 xl:pt-8.5 h-auto xl:h-screen bg-white overflow-hidden relative z-20">
  <div class="container-full flex flex-col xl:flex-row justify-center xl:justify-between 3xl:justify-center items-stretch gap-6 h-full">
    <div class="w-full xl:w-[25%] h-full flex flex-col justify-center items-start gap-6 self-center content-left">
      <h2 class="text-primary title-sm">{content.second.title}</h2>
      <p class="text-paragraph subtitle">{content.second.subtitle}</p>
    </div>
    <div class="w-full h-auto xl:h-full xl:w-auto 3xl:w-[50%] 3xl:h-auto bg-accent js-second-video" style="aspect-ratio: 628/740;"></div>
    <div class="w-full xl:w-[25%] grow flex flex-col justify-center xl:justify-between items-start js-right-content gap-6">
      <div class="flex flex-col justify-center items-start gap-6">
        <p class="text-paragraph paragraph">{content.second.description}</p>
        <a href={content.second.button.href} class="cursor-pointer group flex justify-start items-center gap-2" >
          <p class="text-primary paragraph-bold group-hover:text-accent transition-all duration-300 ease-in-out">{content.second.button.label}</p>
          <img src="/images/arrow.svg" width="16" height="16" decoding="async" loading="lazy" class="w-4 h-4" alt="Arrow Right"/>
        </a>
      </div>
      <img src="/images/logo-2.svg" alt="Logo" width="184" height="184" class="w-[184px] h-[184px]" decoding="async" loading="lazy"/>
    </div>
  </div>
</section>

<script>
  import { gsap, ScrollTrigger } from '../utils/animations';
  import { MEDIA_QUERIES } from '../utils/breakpoints';

  document.addEventListener('DOMContentLoaded', () => {
    gsap.registerPlugin(ScrollTrigger);

    const section = document.querySelector('#fleet-section-2');
    if (!section) return;

    const secondVideo = section.querySelector('.js-second-video');
    const contentLeft  = section.querySelector('.content-left');
    const rightContent = section.querySelector('.js-right-content');

    if (!secondVideo || !contentLeft || !rightContent) {
      console.warn('Faltan elementos en el DOM para iniciar la animación de GSAP en la sección Fleet');
      return;
    }

    let mm = gsap.matchMedia();

    // ==========================================
    // 1. ESCRITORIO (730px en adelante) - Mantiene tu lógica original
    // ==========================================
    mm.add(MEDIA_QUERIES.isDesktopPin, () => {
      gsap.set(secondVideo, { opacity: 0, scale: 0, transformOrigin: "top left" });
      gsap.set(contentLeft, { opacity: 0, xPercent: -100 });
      gsap.set(rightContent, { opacity: 0, xPercent: 100 });

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: "top 80%",         
          end: "+=500",     
          scrub: 1,                 
          invalidateOnRefresh: true 
        }
      });

      tl.to(secondVideo, { opacity: 1, scale: 1, duration: 1, ease: "none" })
        .to(contentLeft, { opacity: 1, xPercent: 0, duration: 0.8, ease: "power2.inOut", immediateRender: false }, "-=0.6")
        .to(rightContent, { opacity: 1, xPercent: 0, duration: 0.8, ease: "power2.inOut" }, "<");
    });

    mm.add(MEDIA_QUERIES.isTabletMobileFlow, () => {
      // Ajustamos sutilmente los valores iniciales para que la entrada fluya mejor en vertical
      gsap.set(contentLeft, { opacity: 0, xPercent: -100 });
      gsap.set(secondVideo, { opacity: 0, scale: 0, transformOrigin: "top left" });
      gsap.set(rightContent, { opacity: 0, xPercent: 100 });

      const tlMobile = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: "top 85%", // Comienza un poco antes al hacer scroll en el móvil
          end: () => window.innerWidth >= 730 ? "+=1500" : "+=900",     // Ofrece un recorrido cómodo para que se completen las 3 animaciones fijas
          scrub: 1
        }
      });

      // Animaciones encadenadas en orden estricto y continuo (sin posiciones relativas como "<" o "-=")
      tlMobile
        // 1. Primero entra contentLeft
        .to(contentLeft, { 
          opacity: 1, 
          xPercent: 0, 
          duration: 1, 
          ease: "power2.out" 
        })
        // 2. Luego aparece secondVideo
        .to(secondVideo, { 
          opacity: 1, 
          scale: 1, 
          duration: 1, 
          ease: "power2.out" 
        })
        // 3. Por último entra rightContent
        .to(rightContent, { 
          opacity: 1, 
          xPercent: 0, 
          duration: 1, 
          ease: "power2.out" 
        });
    });
    
  });
</script>