---
type Translations = typeof import("../i18n/en").default;
type ProjectsContent = Translations["main"]["projects"];
interface Props {
  content: ProjectsContent;
}
const { content } = Astro.props as Props;
---
<section id="fleet-section-2" class="w-full flex flex-col justify-center items-center pb-12 3xl:pb-20 pt-8.5 h-screen bg-white overflow-hidden relative z-20">
  <div class="container-full flex justify-between 3xl:justify-center items-stretch gap-6 h-full">
    <div class="w-[25%] h-full flex flex-col justify-center items-start gap-6 self-center content-left">
      <h2 class="text-primary title-sm">{content.second.title}</h2>
      <p class="text-paragraph subtitle">{content.second.subtitle}</p>
    </div>
    <div class="h-full w-auto 3xl:w-[50%] 3xl:h-auto bg-accent js-second-video" style="aspect-ratio: 628/740;"></div>
    <div class="w-[25%] grow flex flex-col justify-between items-start js-right-content">
      <div class="flex flex-col justify-center items-start gap-6">
        <p class="text-paragraph paragraph">{content.second.description}</p>
        <a href={content.second.button.href} class="cursor-pointer group flex justify-start items-center gap-2" >
          <p class="text-primary paragraph-bold group-hover:text-accent transition-all duration-300 ease-in-out">{content.second.button.label}</p>
          <img src="/images/arrow.svg" width="16" height="16" decoding="async" loading="lazy" class="w-4 h-4" alt="Arrow Right"/>
        </a>
      </div>
      <img src="/images/logo-2.svg" alt="Logo" width="184" height="184" class="w-[184px] h-[184px]" decoding="async" loading="lazy"/>
    </div>
  </div>
</section>

<script>
  import { gsap, ScrollTrigger } from '../utils/animations';

  document.addEventListener('DOMContentLoaded', () => {
    // Registramos el plugin ScrollTrigger
    gsap.registerPlugin(ScrollTrigger);

    const section = document.querySelector('#fleet-section-2');
    if (!section) return;

    // Buscamos los elementos con selectores JS dedicados
    const secondVideo  = section.querySelector('.js-second-video');
    const contentLeft = section.querySelector('.content-left');
    const rightContent   = section.querySelector('.js-right-content');

    // Validación estricta
    if (!secondVideo || !contentLeft || !rightContent) {
      console.warn('Faltan elementos en el DOM para iniciar la animación de GSAP en la sección Fleet');
      return;
    }

    // 1. Preparación de estados iniciales
    gsap.set(secondVideo, { opacity: 0, scale: 0, transformOrigin: "top left" });
    gsap.set(contentLeft, { opacity: 0, xPercent: -100 });
    gsap.set(rightContent, { opacity: 0, xPercent: 100 });

    // 2. Timeline SÍNCRONO con el Scroll (Scrub + Pin)
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: "top 80%",         
        end: "+=700",     
        scrub: 1,                 
        invalidateOnRefresh: true 
      }
    });

    // FASE 1: El Panel Turquesa empieza a crecer (Tiempo: 0.0s a 1.0s)
    tl.to(secondVideo, { 
      opacity: 1, 
      scale: 1, 
      duration: 1, 
      ease: "none" 
    })

    // FASE 2: Entra el primer bloque de texto (Tiempo: 0.4s a 1.2s)
    // Se dispara al 40% del crecimiento del panel turquesa
    .to(contentLeft, { 
      opacity: 1, 
      xPercent: 0, 
      duration: 0.8, 
      ease: "power2.inOut", 
      immediateRender: false 
    }, "-=0.6")

    // El párrafo entra al mismo tiempo que la imagen (<) de la Fase 3
    .to(rightContent, { 
      opacity: 1, 
      xPercent: 0, 
      duration: 0.8, 
      ease: "power2.inOut" 
    }, "<");
    
  });
</script>