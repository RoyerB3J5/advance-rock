---
const icons = [
  {
    name: "mail-white",
    href: "https://mail.google.com/mail/?view=cm&fs=1&to=info@advancerockconcrete.com",
  },
  {
    name: "instagram",
    href: "https://www.instagram.com/advancerockconcrete.usa?igsh=cGlndHF6anRyMHBn",
  },
  {
    name: "facebook",
    href: "https://www.facebook.com/advancerockconcreteusa",
  },
];
---

<div class="flex justify-center items-center gap-4 w-full">
  {
    icons.map((i) => (
      <a href={i.href} class="p-2 rounded-full flex items-center justify-center bg-accent shrink-0">
        <img src={`/images/${i.name}.svg`} alt={i.name} class="w-4 h-4" />
      </a>
    ))
  }
</div>
