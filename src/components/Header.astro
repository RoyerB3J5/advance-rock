---
import Button from "./Button.astro";
import ChangeLanguage from "./ChangeLanguage.astro";

type Translations = typeof import("../i18n/en").default;
type HeaderContent = Translations["header"];
interface Props {
  content?: HeaderContent;
}
const { content } = Astro.props as Props;

// Obtener la ruta actual y normalizar el path sin prefijo de idioma
const currentPath = Astro.url.pathname;
// Normalizar: remover idioma y trailing slash
const normalized =
  currentPath.replace(/^\/(en|es)/, "").replace(/\/$/, "") || "/";
// Detectar el idioma actual ('en' o 'es')
const match = currentPath.match(/^\/(en|es)/);
const lang = match ? match[1] : "en";
const isContactPage = normalized === "/contact";
const isProjectPage = normalized === "/projects";
---

<header
  class={`fixed left-0 right-0 z-50 w-full flex flex-col justify-center items-center top-0`}
  id="site-header"
  style="background-color: transparent; transition: background-color 0.3s ease-out;"
>
  <div class="container-full flex flex-col justify-center items-center">
    {/* Cambio 1: Se agregó 'hidden md:flex' para ocultarlo de md para abajo */}
    <div
      class="hidden md:flex py-2.5 w-full justify-end items-center gap-4 border-b border-white/20 header-container-1"
    >
      {
        isProjectPage ? (
          <img
            src="/images/pin-map-dark.svg"
            alt="Pin Map"
            width="16"
            height="16"
            class="w-4 h-4"
          />
        ) : (
          <img
            src="/images/pin-map.svg"
            alt="Pin Map"
            width="16"
            height="16"
            class="w-4 h-4"
          />
        )
      }
      <p class={`paragraph ${isProjectPage ? "text-primary" : "text-white"}`}>
        Charlotte, NC
      </p>
      <div class={`w-[1px] h-6 ${isProjectPage ? "bg-primary" : "bg-white"}`}>
      </div>
      <p class={`paragraph ${isProjectPage ? "text-primary" : "text-white"}`}>
        Greenville, SC
      </p>
    </div>
    <div class={`w-full flex justify-between items-center relative py-6`}>
      <a
        href={`/${lang}`}
        aria-label="Ir a la página principal"
        title="Advance Rock Concrete - Init"
      >
        {
          isContactPage || isProjectPage ? (
            <img
              src="/images/logo-color.svg"
              alt="Logo de Advance Rock Concrete"
              width="180"
              height="36"
              class="cursor-pointer w-40 md:w-45 h-auto "
            />
          ) : (
            <img
              src="/images/logo.svg"
              alt="Logo de Advance Rock Concrete"
              width="180"
              height="36"
              class="cursor-pointer w-40 md:w-45 h-auto "
            />
          )
        }
      </a>
      <div
        class="relative bg-transparent flex flex-row justify-center items-center h-auto w-auto z-10 transform translate-x-0 transition-transform duration-300 ease-out"
      >
        <nav>
          <ul
            class="hidden relative lg:flex items-center flex-row justify-center w-auto gap-6"
          >
            {
              content?.nav.map((item, index) => {
                const itemPathWithoutHash = item.href.split("#")[0];
                const isActive =
                  normalized === itemPathWithoutHash ||
                  (index === 1 && normalized.startsWith("/services"));
                const isServices = index === 1;
                return (
                  <li
                    class={`flex flex-row items-center justify-center group hover:text-accent w-auto text-center ${isServices ? "relative dropdown-parent" : ""} ${isActive ? "bg-transparent " : ""}`}
                    id={`services-${index}`}
                  >
                    <a
                      href={`/${lang}${item.href}`}
                      class=" relative transition-colors duration-300 flex justify-center items-center"
                    >
                      <p
                        class={`paragraph  transition-all duration-300 ease-in-out ${isProjectPage ? "text-primary" : "text-white"}`}
                        set:html={item.label}
                      />
                      {isServices && (
                        <img
                          src={
                            isProjectPage
                              ? "/images/arrow-d-g-color.svg"
                              : "/images/arrow-d-g.svg"
                          }
                          alt="Arrow"
                          class="inline-block w-6 h-6 ml-1"
                        />
                      )}
                      <span
                        class={`absolute -bottom-2 left-1/2 h-0.5 bg-accent transition-all duration-300 ease-out -translate-x-1/2 ${isActive ? "w-8" : "w-0 group-hover:w-8 group-hover:bg-accent"}`}
                      />
                    </a>
                    {isServices && (
                      <div class="dropdown-menu absolute top-9 left-0 mt-0 w-[283px] flex-col items-center bg-primary-back z-40 hidden group-hover:flex opacity-0 group-hover:opacity-100 pointer-events-none group-hover:pointer-events-auto transition-all duration-200 ease-out -translate-x-[25%] overflow-hidden ">
                        {content.services.map((sub) => (
                          <div class="text-[17px] leading-[150%] text-white hover:text-secondary transition-colors duration-200 ease-in-out cursor-pointer px-4 w-full text-center py-3 flex justify-between items-center hover:bg-[#001A1F] w-full font-normal font-paragraph">
                            <a href={`${sub.href}`} >
                              {sub.label}
                            </a>
                            <img
                              src="/images/arrow-red.svg"
                              alt="Arrow"
                              class="inline-block w-6 h-6 "
                            />
                          </div>
                        ))}
                      </div>
                    )}
                  </li>
                );
              })
            }
          </ul>
        </nav>
      </div>
      <div class="flex justify-center items-center gap-6">
        <Button
          text={content?.buttons[0].label}
          href={content?.buttons[0].href}
          textClass="text-[17px]"
          extraBtnClass="hidden xl:block"
        />
        <ChangeLanguage isProjectPage={isProjectPage} />
        <button
          type="button"
          aria-label="Abrir menú de navegación"
          title="Abrir menú"
          class="flex lg:hidden items-center justify-center cursor-pointer w-8 h-8 bg-accent rounded-sm"
          id="hamburger-btn"
        >
          <img
            src="/images/hamburger.svg"
            alt="Menú"
            width="18"
            height="12"
            class="w-3 h-auto block"
          />
          <span class="sr-only">Abrir menú de navegación</span>
        </button>
      </div>
    </div>
  </div>
</header>

<div
  class="fixed top-0 right-0 bottom-0 lg:hidden flex items-start bg-primary-back text-white flex-col justify-center h-[85%] z-60 py-6 gap-12 transform -translate-y-full transition-transform duration-300 ease-out w-full"
  id="mobile-menu"
>
  <img
    src="/images/equis.svg"
    alt="Cerrar menú"
    width="24"
    height="24"
    class="block absolute top-6 right-6 cursor-pointer z-20"
    id="close-btn"
    aria-label="Cerrar menú de navegación"
    title="Cerrar menú"
    role="button"
    tabindex="0"
  />
  <a
    href={`/${lang}`}
    aria-label="Ir a la página principal"
    title="Advance Rock Concrete - Init "
  >
    <img
      src="/images/logo-color.svg"
      alt="Logo de Advance Rock Concrete"
      width="180"
      height="36"
      class="cursor-pointer w-45 h-auto ml-4"
    />
  </a>
  <nav class="w-full px-4">
    <ul class="relative flex items-start flex-col justify-center w-full">
      {
        content?.nav.map((item, index) => {
          const itemPathWithoutHash = item.href.split("#")[0];
          const isActive =
            normalized === itemPathWithoutHash ||
            (index === 1 && normalized.startsWith("/services"));
          const isServices = index === 1;
          return (
            <li
              class={` flex flex-col items-start justify-center group gap-3.5 px-0 w-full py-5 text-start text-white ${isServices ? "relative" : ""} ${isActive ? "bg-accent text-white uppercase px-4" : ""}`}
              id={`mobile-services-${index}`}
            >
              <a
                href={`/${lang}${item.href}`}
                class="relative transition-colors duration-300 flex justify-center items-center "
              >
                <p class="font-paragraph font-semibold text-[15px] leading-[150%]" set:html={item.label} />
                {isServices && (
                  <img
                    src={`
                      ${isActive ? "/images/arrow-d-g-color.svg" : "/images/arrow-red.svg"}`
                    }
                    alt="Arrow"
                    class={`inline-block w-6 h-6 ml-2 ${isActive ? "" : "transform rotate-90"}`}
                  />
                )}
              </a>
              {isServices && (
                <div
                  class={`flex-col justify-center items-center w-full bg-secondary divide-y divide-accent hidden absolute z-20 top-0 translate-y-12.5 ${isActive ? "-translate-x-4" : ""}`}
                  id="sub-menu-services"
                >
                  {content.services.map((sub) => (
                    <a
                      href={`${sub.href}`}
                      class="paragraph text-white py-4 transition-colors duration-300 ease-in-out cursor-pointer px-6 w-full text-center font-semibold"
                    >
                      {sub.label}
                    </a>
                    
                  ))}
                  <a
                      href={`${content.all.href}`}
                      class="paragraph text-white py-4 transition-colors duration-300 ease-in-out cursor-pointer px-6 w-full text-center font-semibold"
                    >
                      {content.all.label}
                    </a>
                </div>
              )}
            </li>
          );
        })
      }
    </ul>
  </nav>

  <div class="flex flex-col justify-center items-center gap-5 w-full px-4">
    <Button
      text={content?.buttons[0].label}
      textClass="text-[17px]"
      href={content?.buttons[0].href}
      target="_blank"
      extraBtnClass={`bg-accent w-full`}
    />
  </div>

  <style>
    /* Estilos del dropdown heredados */
    .dropdown-parent:hover .dropdown-menu {
      display: flex !important;
      opacity: 1 !important;
      pointer-events: auto !important;
    }
    .dropdown-parent::after {
      content: "";
      position: absolute;
      top: 100%;
      left: -10px;
      right: -10px;
      height: 10px;
      background: transparent;
      z-index: 39;
      pointer-events: auto;
    }
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
    .dropdown-menu:hover {
      display: flex !important;
      opacity: 1 !important;
      pointer-events: auto !important;
    }
    @media (max-width: 1023px) {
      .dropdown-parent::after {
        display: none;
      }
      .dropdown-parent:hover .dropdown-menu {
        display: none !important;
      }
      .dropdown-menu {
        display: none !important;
      }
    }
  </style>
</div>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  document.addEventListener("DOMContentLoaded", () => {
    // 1. LÓGICA DEL MENÚ MÓVIL (Intacta)
    const menu = document.getElementById("mobile-menu");
    const openBtn = document.getElementById("hamburger-btn");
    const closeBtn = document.getElementById("close-btn");
    const servicesDiv = document.getElementById("services-1");
    const mobileservicesDiv = document.getElementById("mobile-services-1");
    const subMenuservices = document.getElementById("sub-menu-services");
    const body = document.body;

    const isMobile = () => window.innerWidth < 1024;

    function openMenu() {
      if (isMobile() && menu) {
        menu.classList.replace("-translate-y-full", "translate-y-0");
        body.classList.add("overflow-hidden");
      }
    }

    function closeMenu() {
      if (isMobile() && menu) {
        menu.classList.replace("translate-y-0", "-translate-y-full");
        body.classList.remove("overflow-hidden");
      }
    }

    function toggleSubMenu(event: Event) {
      if (!isMobile() || !subMenuservices) return;
      const isSubMenuOpen = !subMenuservices.classList.contains("hidden");
      event.preventDefault();5
      if (!isSubMenuOpen) {
        subMenuservices.classList.remove("hidden");
        subMenuservices.classList.add("flex");
      } else {
        subMenuservices.classList.add("hidden");
        subMenuservices.classList.remove("flex");
      }
    }

    if (openBtn) openBtn.addEventListener("click", openMenu);
    if (closeBtn) closeBtn.addEventListener("click", closeMenu);

    if (servicesDiv) {
      servicesDiv.addEventListener("click", (e) => {
        if (
          !isMobile() ||
          (e.target as HTMLElement).closest("#sub-menu-services")
        )
          return;
        toggleSubMenu(e);
      });
    }

    if (mobileservicesDiv) {
      mobileservicesDiv.addEventListener("click", (e) => {
        if (
          !isMobile() ||
          (e.target as HTMLElement).closest("#sub-menu-services")
        )
          return;
        toggleSubMenu(e);
      });
    }

    // 2. LÓGICA DEL HEADER (Fondo y GSAP ScrollTrigger)
    const header: HTMLElement | null = document.getElementById("site-header");
    const firstContainerHedaer = document.querySelector(".header-container-1") as HTMLElement | null;
    if (!header || !firstContainerHedaer) return;

    gsap.registerPlugin(ScrollTrigger);

    // Actualizar fondo independientemente de la página (unificado)
    const updateHeaderStyle = () => {
      const scrollY = window.scrollY || document.documentElement.scrollTop;
      const firstSection = document.querySelector(".hero-main-section") || document.querySelector("main > section");
      const threshold = firstSection ? (firstSection as HTMLElement).offsetHeight : window.innerHeight;

      if (scrollY >= threshold) {
        header.style.backgroundColor = "var(--color-primary-rgb)";
        firstContainerHedaer.style.display = "none"; 
      } else {
        header.style.backgroundColor = "transparent";
        // Cambio adicional preventivo: solo forzar flex si no estamos en móvil, respetando Cambio 1
        if (window.innerWidth >= 768) {
          firstContainerHedaer.style.display = "flex";
        }
      }
    };

    window.addEventListener("scroll", updateHeaderStyle, { passive: true });
    updateHeaderStyle(); // Aplicar al cargar

    // Usar ScrollTrigger para ocultar/mostrar el header
    // Esto se sincroniza perfectamente con el resto de tus animaciones GSAP
    ScrollTrigger.create({
      start: "top top",
      end: "max",
      onUpdate: (self) => {
        // Cambio 2: Se eliminó la condicional "window.scrollY > viewportHeight" para que actúe apenas haga scroll down (> 0)
        if (self.direction === 1 && window.scrollY > 0) {
          gsap.to(header, {
            yPercent: -120,
            duration: 0.3,
            ease: "power2.out",
            overwrite: true,
          });
        }
        // Si el usuario hace scroll hacia arriba (-1)
        else if (self.direction === -1) {
          gsap.to(header, {
            yPercent: 0,
            duration: 0.3,
            ease: "power2.out",
            overwrite: true,
          });
        }
      },
    });

    // 3. ACTUALIZAR VARIABLE CSS DE ALTURA
    function updateHeaderHeight() {
      const height = header?.offsetHeight || 0;
      document.documentElement.style.setProperty(
        "--header-height",
        `${height}px`,
      );
    }
    updateHeaderHeight();
    window.addEventListener("resize", updateHeaderHeight);
  });
</script>